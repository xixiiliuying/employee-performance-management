<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dao.JobDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.entity.JobEntity" id="gangweiMap">
        <result property="jname" column="Jname"/>
    </resultMap>

	<select id="selectListVO"
		resultType="com.entity.vo.JobVO" >
		SELECT * FROM jobs  jobs
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectVO"
		resultType="com.entity.vo.JobVO" >
		SELECT  jobs.* FROM jobs  jobs
 		<where> 1=1 ${ew.sqlSegment}</where>
	</select>

    <select id="selectListView"
		resultType="com.entity.view.JobView" >

		SELECT  jobs.* FROM jobs  jobs
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.entity.view.JobView" >
		SELECT * FROM jobs  jobs <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
</mapper>