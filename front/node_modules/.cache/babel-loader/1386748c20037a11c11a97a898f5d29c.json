-card employee-card\" shadow=\"hover\" @click.native=\"$router.push('/index/hr/employee')\">\r\n          <div class=\"stat-content\">\r\n            <div class=\"stat-icon\"><i class=\"el-icon-user-solid\"></i></div>\r\n            <div class=\"stat-info\">\r\n              <div class=\"stat-value\">{{ stats.totalEmployees || 156 }}</div>\r\n              <div class=\"stat-label\">总员工数</div>\r\n              <div class=\"stat-trend trend-up\">\r\n                <i class=\"el-icon-top\"></i>\r\n                <span>较上月 +5%</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n\r\n      <el-col :xs=\"12\" :sm=\"6\" :md=\"6\" :lg=\"6\">\r\n        <el-card class=\"stat-card attendance-card\" shadow=\"hover\" @click.native=\"$router.push('/index/hr/attendance-manage')\">\r\n          <div class=\"stat-content\">\r\n            <div class=\"stat-icon\"><i class=\"el-icon-check\"></i></div>\r\n            <div class=\"stat-info\">\r\n              <div class=\"stat-value\">{{ stats.todayAttendance || 148 }}</div>\r\n              <div class=\"stat-label\">今日出勤</div>\r\n              <div class=\"stat-trend\">\r\n                <span class=\"attendance-rate\">出勤率 {{ stats.attendanceRate }}%</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n\r\n      <el-col :xs=\"12\" :sm=\"6\" :md=\"6\" :lg=\"6\">\r\n        <el-card class=\"stat-card approval-card\" shadow=\"hover\" @click.native=\"$router.push('/index/hr/leave-manage')\">\r\n          <div class=\"stat-content\">\r\n            <div class=\"stat-icon\"><i class=\"el-icon-document\"></i></div>\r\n            <div class=\"stat-info\">\r\n              <div class=\"stat-value\">{{ stats.pendingApproval || 12 }}</div>\r\n              <div class=\"stat-label\">待审批</div>\r\n              <div class=\"stat-trend trend-warning\">\r\n                <i class=\"el-icon-warning\"></i>\r\n                <span>需及时处理</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n\r\n      <el-col :xs=\"12\" :sm=\"6\" :md=\"6\" :lg=\"6\">\r\n        <el-card class=\"stat-card department-card\" shadow=\"hover\" @click.native=\"$router.push('/index/hr/department')\">\r\n          <div class=\"stat-content\">\r\n            <div class=\"stat-icon\"><i class=\"el-icon-office-building\"></i></div>\r\n            <div class=\"stat-info\">\r\n              <div class=\"stat-value\">{{ stats.totalDepartments || 8 }}</div>\r\n              <div class=\"stat-label\">部门数量</div>\r\n              <div class=\"stat-trend\">\r\n                <span class=\"dept-info\">{{ stats.largestDept }}</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <el-row :gutter=\"20\" class=\"main-content\">\r\n      <el-col :xs=\"24\" :sm=\"16\" :md=\"16\" :lg=\"16\">\r\n        <el-row :gutter=\"20\" class=\"function-modules\">\r\n          <el-col :xs=\"24\" :sm=\"12\" :md=\"12\" :lg=\"12\">\r\n            <el-card class=\"module-card employee-module\" shadow=\"hover\" @click.native=\"$router.push('/index/hr/employee')\">\r\n              <div class=\"module-header\">\r\n                <div class=\"module-icon\"><i class=\"el-icon-user-solid\"></i></div>\r\n                <div class=\"module-title\">\r\n                  <h3>员工管理</h3>\r\n                  <p>员工信息与档案</p>\r\n                </div>\r\n              </div>\r\n              <div class=\"module-content employee-stats\">\r\n                <div class=\"stat-item\">\r\n                  <div class=\"item-value\">12</div>\r\n                  <div class=\"item-label\">本月入职</div>\r\n                </div>\r\n                <div class=\"stat-item\">\r\n                  <div class=\"item-value\">3</div>\r\n                  <div class=\"item-label\">本月离职</div>\r\n                </div>\r\n              </div>\r\n            </el-card>\r\n          </el-col>\r\n\r\n          <el-col :xs=\"24\" :sm=\"12\" :md=\"12\" :lg=\"12\">\r\n            <el-card class=\"module-card attendance-module\" shadow=\"hover\" @click.native=\"$router.push('/index/hr/attendance-manage')\">\r\n              <div class=\"module-header\">\r\n                <div class=\"module-icon\"><i class=\"el-icon-time\"></i></div>\r\n                <div class=\"module-title\">\r\n                  <h3>考勤管理</h3>\r\n                  <p>考勤统计与异常</p>\r\n                </div>\r\n              </div>\r\n              <div class=\"module-content attendance-details\">\r\n                <div class=\"detail-item\">\r\n                  <span class=\"label\">异常考勤</span>\r\n                  <span class=\"value detail-danger\">8人</span>\r\n                </div>\r\n                <div class=\"detail-item\">\r\n                  <span class=\"label\">未打卡</span>\r\n                  <span class=\"value\">5人</span>\r\n                </div>\r\n              </div>\r\n            </el-card>\r\n          </el-col>\r\n\r\n          <el-col :xs=\"24\" :sm=\"12\" :md=\"12\" :lg=\"12\">\r\n            <el-card class=\"module-card salary-module\" shadow=\"hover\" @click.native=\"$router.push('/index/hr/salary-manage')\">\r\n              <div class=\"module-header\">\r\n                <div class=\"module-icon\"><i class=\"el-icon-money\"></i></div>\r\n                <div class=\"module-title\">\r\n                  <h3>薪资管理</h3>\r\n                  <p>工资核算与发放</p>\r\n                </div>\r\n              </div>\r\n              <div class=\"module-content salary-overview\">\r\n                <div class=\"salary-total\">\r\n                  <span class=\"currency\">¥</span>\r\n                  <span class=\"amount\">856,200</span>\r\n                </div>\r\n                <div class=\"salary-period\">本月应发总额</div>\r\n              </div>\r\n            </el-card>\r\n          </el-col>\r\n\r\n          <el-col :xs=\"24\" :sm=\"12\" :md=\"12\" :lg=\"12\">\r\n            <el-card class=\"module-card leave-module\" shadow=\"hover\" @click.native=\"$router.push('/index/hr/leave-manage')\">\r\n              <div class=\"module-header\">\r\n                <div class=\"module-icon\"><i class=\"el-icon-date\"></i></div>\r\n                <div class=\"module-title\">\r\n                  <h3>请假审批</h3>\r\n                  <p>请假申请处理</p>\r\n                </div>\r\n              </div>\r\n              <div class=\"module-content leave-stats\">\r\n                <div class=\"stat-item\">\r\n                  <div class=\"item-value stat-warning\">8</div>\r\n                  <div class=\"item-label\">待审批</div>\r\n                </div>\r\n                <div class=\"stat-item\">\r\n                  <div class=\"item-value\">23</div>\r\n                  <div class=\"item-label\">本月已批</div>\r\n                </div>\r\n              </div>\r\n            </el-card>\r\n          </el-col>\r\n        </el-row>\r\n\r\n        <el-card class=\"todo-section\" shadow=\"never\">\r\n          <template #header>\r\n            <div class=\"card-header\">\r\n              <span>待办事项</span>\r\n              <el-tag size=\"small\" type=\"danger\">{{ pendingTasks.length }} 条</el-tag>\r\n            </div>\r\n          </template>\r\n          <div class=\"todo-list\">\r\n            <div\r\n                v-for=\"task in pendingTasks\"\r\n                :key=\"task.id\"\r\n                class=\"todo-item\"\r\n                @click=\"handleTaskClick(task)\"\r\n            >\r\n              <div class=\"todo-badge\" :class=\"task.type\">\r\n                <i :class=\"task.icon\"></i>\r\n              </div>\r\n              <div class=\"todo-content\">\r\n                <div class=\"todo-title\">{{ task.title }}</div>\r\n                <div class=\"todo-meta\">\r\n                  <span class=\"todo-time\">{{ task.time }}</span>\r\n                  <el-tag v-if=\"task.urgent\" type=\"danger\" size=\"mini\">紧急</el-tag>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n\r\n      <el-col :xs=\"24\" :sm=\"8\" :md=\"8\" :lg=\"8\">\r\n        <el-card class=\"info-card department-card\" shadow=\"never\">\r\n          <template #header>\r\n            <div class=\"card-header\">\r\n              <span>部门分布</span>\r\n            </div>\r\n          </template>\r\n          <div class=\"department-chart\">\r\n            <div\r\n                v-for=\"dept in departmentStats\"\r\n                :key=\"dept.name\"\r\n                class=\"department-item\"\r\n            >\r\n              <div class=\"dept-info\">\r\n                <span class=\"dept-name\">{{ dept.name }}</span>\r\n                <span class=\"dept-count\">{{ dept.count }}人</span>\r\n              </div>\r\n              <el-progress\r\n                  :percentage=\"dept.percentage\"\r\n                  :color=\"dept.color\"\r\n                  :show-text=\"false\"\r\n                  :stroke-width=\"8\"\r\n              ></el-progress>\r\n              <span class=\"dept-percentage\">{{ dept.percentage }}%</span>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n\r\n        <el-card class=\"info-card activity-card\" shadow=\"never\">\r\n          <template #header>\r\n            <div class=\"card-header\">\r\n              <span>最近动态</span>\r\n            </div>\r\n          </template>\r\n          <div class=\"activity-list\">\r\n            <div\r\n                v-for=\"activity in recentActivities\"\r\n                :key=\"activity.id\"\r\n                class=\"activity-item\"\r\n            >\r\n              <div class=\"activity-icon\" :class=\"activity.type\">\r\n                <i :class=\"activity.icon\"></i>\r\n              </div>\r\n              <div class=\"activity-content\">\r\n                <div class=\"activity-text\">{{ activity.text }}</div>\r\n                <div class=\"activity-time\">{{ activity.time }}</div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'HrIndexPage',\r\n  data() {\r\n    return {\r\n      stats: {\r\n        totalEmployees: 156,\r\n        todayAttendance: 148,\r\n        pendingApproval: 12,\r\n        totalDepartments: 8,\r\n        attendanceRate: 94.9,\r\n        largestDept: '技术部'\r\n      },\r\n      pendingTasks: [\r\n        {\r\n          id: 1,\r\n          type: 'leave',\r\n          icon: 'el-icon-date',\r\n          title: '张三 - 事假申请 3天',\r\n          time: '2小时前',\r\n          urgent: true\r\n        },\r\n        {\r\n          id: 2,\r\n          type: 'salary',\r\n          icon: 'el-icon-money',\r\n          title: '李四 - 调薪申请审批',\r\n          time: '4小时前',\r\n          urgent: false\r\n        },\r\n        {\r\n          id: 3,\r\n          type: 'attendance',\r\n          icon: 'el-icon-time',\r\n          title: '王五 - 考勤异常处理',\r\n          time: '1天前',\r\n          urgent: true\r\n        }\r\n      ],\r\n      departmentStats: [\r\n        { name: '技术部', count: 45, percentage: 29, color: '#409EFF' },\r\n        { name: '销售部', count: 38, percentage: 24, color: '#67C23A' },\r\n        { name: '市场部', count: 25, percentage: 16, color: '#E6A23C' },\r\n        { name: '人事部', count: 18, percentage: 12, color: '#F56C6C' },\r\n        { name: '财务部', count: 15, percentage: 10, color: '#909399' }\r\n      ],\r\n      recentActivities: [\r\n        {\r\n          id: 1,\r\n          type: 'new',\r\n          icon: 'el-icon-user-solid',\r\n          text: '新员工 赵六 完成入职',\r\n          time: '今天 09:30'\r\n        },\r\n        {\r\n          id: 2,\r\n          type: 'leave',\r\n          icon: 'el-icon-document',\r\n          text: '钱七 提交了3天事假申请',\r\n          time: '今天 08:45'\r\n        },\r\n        {\r\n          id: 3,\r\n          type: 'salary',\r\n          icon: 'el-icon-money',\r\n          text: '1月份薪资核算已完成',\r\n          time: '昨天 17:20'\r\n        }\r\n      ],\r\n      currentDate: ''\r\n    }\r\n  },\r\n  mounted() {\r\n    this.setCurrentDate();\r\n  },\r\n  methods: {\r\n    setCurrentDate() {\r\n      const now = new Date();\r\n      const options = { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' };\r\n      this.currentDate = now.toLocaleDateString('zh-CN', options);\r\n    },\r\n\r\n    handleTaskClick(task) {\r\n      const routeMap = {\r\n        leave: '/index/hr/leave-manage',\r\n        salary: '/index/hr/salary-manage',\r\n        attendance: '/index/hr/attendance-manage',\r\n        employee: '/index/hr/employee'\r\n      };\r\n\r\n      if (routeMap[task.type]) {\r\n        this.$router.push(routeMap[task.type]);\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.hr-dashboard {\r\n  padding: 20px;\r\n  background-color: #f5f7fa;\r\n  min-height: calc(100vh - 60px);\r\n}\r\n\r\n.page-header {\r\n  margin-bottom: 24px;\r\n}\r\n\r\n.page-header h1 {\r\n  margin: 0;\r\n  color: #303133;\r\n  font-size: 24px;\r\n  font-weight: 600;\r\n}\r\n\r\n.page-header p {\r\n  margin: 8px 0 0 0;\r\n  color: #909399;\r\n  font-size: 14px;\r\n}\r\n\r\n/* 核心数据卡片 */\r\n.core-stats {\r\n  margin-bottom: 24px;\r\n}\r\n\r\n.stat-card {\r\n  border-radius: 12px;\r\n  border: none;\r\n  cursor: pointer;\r\n  transition: all 0.3s ease;\r\n  height: 120px;\r\n  margin-bottom: 16px;\r\n}\r\n\r\n.stat-card:hover {\r\n  transform: translateY(-3px);\r\n  box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1) !important;\r\n}\r\n\r\n.stat-content {\r\n  display: flex;\r\n  align-items: center;\r\n  height: 100%;\r\n  padding: 0 20px;\r\n}\r\n\r\n.stat-icon {\r\n  width: 50px;\r\n  height: 50px;\r\n  border-radius: 12px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  margin-right: 15px;\r\n  font-size: 24px;\r\n  color: 