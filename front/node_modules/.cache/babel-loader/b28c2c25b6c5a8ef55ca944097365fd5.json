s-form\" :model=\"ruleForm\" label-width=\"120px\">\n          <el-form-item label=\"员工号\" class=\"input\">\n            <el-input v-model=\"ruleForm.sid\" autocomplete=\"off\" placeholder=\"员工号\" type=\"number\" />\n          </el-form-item>\n          <el-form-item label=\"员工姓名\" class=\"input\">\n            <el-input v-model=\"ruleForm.sname\" autocomplete=\"off\" placeholder=\"员工姓名\" />\n          </el-form-item>\n          <el-form-item label=\"密码\" class=\"input\">\n            <el-input v-model=\"ruleForm.password\" autocomplete=\"off\" placeholder=\"密码\" type=\"password\" />\n          </el-form-item>\n          <el-form-item label=\"性别\" class=\"input\">\n            <el-select v-model=\"ruleForm.gender\" placeholder=\"请选择性别\">\n              <el-option label=\"男\" value=\"男\"></el-option>\n              <el-option label=\"女\" value=\"女\"></el-option>\n            </el-select>\n          </el-form-item>\n          <el-form-item label=\"部门\" class=\"input\">\n            <el-select v-model=\"ruleForm.deptId\" placeholder=\"请选择部门\" clearable>\n              <el-option\n                  v-for=\"item in departmentOptions\"\n                  :key=\"item.id\"\n                  :label=\"item.dname\"\n                  :value=\"item.id\">\n              </el-option>\n            </el-select>\n          </el-form-item>\n          <el-form-item label=\"岗位\" class=\"input\">\n            <el-select v-model=\"ruleForm.jobId\" placeholder=\"请选择岗位\" clearable>\n              <el-option\n                  v-for=\"item in jobOptions\"\n                  :key=\"item.id\"\n                  :label=\"item.jname\"\n                  :value=\"item.id\">\n              </el-option>\n            </el-select>\n          </el-form-item>\n          <el-form-item label=\"联系电话\" class=\"input\">\n            <el-input v-model=\"ruleForm.phone\" autocomplete=\"off\" placeholder=\"联系电话\" />\n          </el-form-item>\n          <el-form-item label=\"邮箱\" class=\"input\">\n            <el-input v-model=\"ruleForm.email\" autocomplete=\"off\" placeholder=\"邮箱\" />\n          </el-form-item>\n          <div style=\"display: flex;flex-wrap: wrap;width: 100%;justify-content: center;\">\n            <el-button class=\"btn\" type=\"primary\" @click=\"register()\">注册</el-button>\n            <el-button class=\"btn close\" type=\"primary\" @click=\"close()\">取消</el-button>\n          </div>\n        </el-form>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      ruleForm: {\n        sid: \"\",\n        sname: \"\",\n        password: \"\",\n        gender: \"\",\n        phone: \"\",\n        email: \"\",\n        deptId: \"\",\n        jobId: \"\",\n        role: \"staff\" // 默认角色为员工\n      },\n      departmentOptions: [],\n      jobOptions: []\n    };\n  },\n  mounted() {\n    this.loadDepartmentOptions();\n    this.loadJobOptions();\n  },\n  methods: {\n    close(){\n      this.$router.push({ path: \"/login\" });\n    },\n\n    // 加载部门选项\n    loadDepartmentOptions() {\n      this.$http({\n        url: this.$api.url.department.list,\n        method: \"get\",\n        params: {\n          page: 1,\n          limit: 100\n        }\n      }).then(({ data }) => {\n        if (data && data.code === 0) {\n          this.departmentOptions = data.data.records || data.data;\n        } else {\n          this.$message.error(data.msg);\n        }\n      }).catch(error => {\n        console.error('获取部门选项失败:', error);\n      });\n    },\n\n    // 加载岗位选项\n    loadJobOptions() {\n      this.$http({\n        url: this.$api.url.job.list,\n        method: \"get\",\n        params: {\n          page: 1,\n          limit: 100\n        }\n      }).then(({ data }) => {\n        if (data && data.code === 0) {\n          this.jobOptions = data.data.records || data.data;\n        } else {\n          this.$message.error(data.msg);\n        }\n      }).catch(error => {\n        console.error('获取岗位选项失败:', error);\n      });\n    },\n\n    // 注册\n    register() {\n      if(!this.ruleForm.sid){\n        this.$message.error(`员工号不能为空`);\n        return\n      }\n      if(!this.ruleForm.sname){\n        this.$message.error(`员工姓名不能为空`);\n        return\n      }\n      if(!this.ruleForm.password){\n        this.$message.error(`密码不能为空`);\n        return\n      }\n      if(!this.ruleForm.gender){\n        this.$message.error(`请选择性别`);\n        return\n      }\n      if(this.ruleForm.phone && (!this.$validate.isMobile(this.ruleForm.phone))){\n        this.$message.error(`联系电话应输入手机格式`);\n        return\n      }\n      if(this.ruleForm.email && (!this.$validate.isEmail(this.ruleForm.email))){\n        this.$message.error(`邮箱应输入邮件格式`);\n        return\n      }\n\n      this.$http({\n        url: this.$api.url.user.register,\n        method: \"post\",\n        data: this.ruleForm\n      }).then(({ data }) => {\n        if (data && data.code === 0) {\n          this.$message({\n            message: \"注册成功\",\n            type: \"success\",\n            duration: 1500,\n            onClose: () => {\n              this.$router.replace({ path: \"/login\" });\n            }\n          });\n        } else {\n          this.$message.error(data.msg);\n        }\n      }).catch(error => {\n        console.error(\"注册失败:\", error);\n        this.$message.error(\"注册失败，请稍后重试\");\n      });\n    }\n  }\n};\n</script>\n\n<!-- 样式保持不变 -->\n<style lang=\"scss\" scoped>\n\t.el-radio__input.is-checked .el-radio__inner {\n\t\tborder-color: #00c292;\n\t\tbackground: #00c292;\n\t}\n\n\t.el-radio__input.is-checked .el-radio__inner {\n\t\tborder-color: #00c292;\n\t\tbackground: #00c292;\n\t}\n\n\t.el-radio__input.is-checked .el-radio__inner {\n\t\tborder-color: #00c292;\n\t\tbackground: #00c292;\n\t}\n\n\t.el-radio__input.is-checked+.el-radio__label {\n\t\tcolor: #00c292;\n\t}\n\n\t.el-radio__input.is-checked+.el-radio__label {\n\t\tcolor: #00c292;\n\t}\n\n\t.el-radio__input.is-checked+.el-radio__label {\n\t\tcolor: #00