input>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"员工姓名\" prop=\"sname\">\r\n            <el-input v-model=\"ruleForm.sname\" placeholder=\"员工姓名\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"性别\" prop=\"gender\">\r\n            <el-select v-model=\"ruleForm.gender\" placeholder=\"请选择性别\">\r\n              <el-option label=\"男\" value=\"男\"></el-option>\r\n              <el-option label=\"女\" value=\"女\"></el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"角色\" prop=\"role\">\r\n            <el-input v-model=\"ruleForm.role\" readonly placeholder=\"角色\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"部门\" prop=\"deptId\">\r\n            <el-select v-model=\"ruleForm.deptId\" placeholder=\"请选择部门\" clearable>\r\n              <el-option\r\n                  v-for=\"item in departmentOptions\"\r\n                  :key=\"item.id\"\r\n                  :label=\"item.dname\"\r\n                  :value=\"item.id\">\r\n              </el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"岗位\" prop=\"jobId\">\r\n            <el-select v-model=\"ruleForm.jobId\" placeholder=\"请选择岗位\" clearable>\r\n              <el-option\r\n                  v-for=\"item in jobOptions\"\r\n                  :key=\"item.id\"\r\n                  :label=\"item.jname\"\r\n                  :value=\"item.id\">\r\n              </el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"联系电话\" prop=\"phone\">\r\n            <el-input v-model=\"ruleForm.phone\" placeholder=\"联系电话\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"邮箱\" prop=\"email\">\r\n            <el-input v-model=\"ruleForm.email\" placeholder=\"邮箱\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"入职日期\" prop=\"hireDate\">\r\n            <el-date-picker\r\n                v-model=\"ruleForm.hireDate\"\r\n                type=\"date\"\r\n                placeholder=\"选择入职日期\"\r\n                value-format=\"yyyy-MM-dd\"\r\n                readonly>\r\n            </el-date-picker>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"24\">\r\n          <el-form-item>\r\n            <el-button type=\"primary\" @click=\"onUpdateHandler\">修 改</el-button>\r\n          </el-form-item>\r\n        </el-col>\r\n      </el-row>\r\n    </el-form>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { isEmail, isMobile } from \"@/utils/validate\";\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      ruleForm: {},\r\n      departmentOptions: [],\r\n      jobOptions: []\r\n    };\r\n  },\r\n  mounted() {\r\n    this.getUserInfo();\r\n    this.loadDepartmentOptions();\r\n    this.loadJobOptions();\r\n  },\r\n  methods: {\r\n    getUserInfo() {\r\n      this.$http({\r\n        url: this.$api.url.user.session,\r\n        method: \"get\"\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.ruleForm = data.data;\r\n          console.log('获取用户信息成功:', this.ruleForm);\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('获取用户信息失败:', error);\r\n        this.$message.error('获取用户信息失败');\r\n      });\r\n    },\r\n\r\n    // 加载部门选项\r\n    loadDepartmentOptions() {\r\n      this.$http({\r\n        url: this.$api.url.department.list,\r\n        method: \"get\",\r\n        params: {\r\n          page: 1,\r\n          limit: 100\r\n        }\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.departmentOptions = data.data.records || data.data;\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('获取部门选项失败:', error);\r\n      });\r\n    },\r\n\r\n    // 加载岗位选项\r\n    loadJobOptions() {\r\n      this.$http({\r\n        url: this.$api.url.job.list,\r\n        method: \"get\",\r\n        params: {\r\n          page: 1,\r\n          limit: 100\r\n        }\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.jobOptions = data.data.records || data.data;\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('获取岗位选项失败:', error);\r\n      });\r\n    },\r\n\r\n    onUpdateHandler() {\r\n      // 表单验证\r\n      if(!this.ruleForm.sid){\r\n        this.$message.error('员工号不能为空');\r\n        return\r\n      }\r\n      if(!this.ruleForm.sname){\r\n        this.$message.error('员工姓名不能为空');\r\n        return\r\n      }\r\n      if(this.ruleForm.phone && (!isMobile(this.ruleForm.phone))){\r\n        this.$message.error(`联系电话应输入手机格式`);\r\n        return\r\n      }\r\n      if(this.ruleForm.email && (!isEmail(this.ruleForm.email))){\r\n        this.$message.error(`邮箱应输入邮箱格式`);\r\n        return\r\n      }\r\n\r\n      // 更新用户信息\r\n      this.$http({\r\n        url: this.$api.url.user.update,\r\n        method: \"post\",\r\n        data: this.ruleForm\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.$message({\r\n            message: \"修改信息成功\",\r\n            type: \"success\",\r\n            duration: 1500\r\n          });\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('更新用户信息失败:', error);\r\n        this.$message.error('更新失败，请稍后重试');\r\n      });\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.detail-form-content {\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n\r\n  .el-row {\r\n    margin-bottom: 20px;\r\n  }\r\n\r\n  .el-col {\r\n    padding: 0 10px;\r\n  }\r\n\r\n  .el-form-item {\r\n    margin-bottom: 20px;\r\n\r\n    .el-input, .el-select, .el-date-picker {\r\n      width: 100%;\r\n    }\r\n  }\r\n\r\n  .el-button {\r\n    width: 200px;\r\n    margin-top: 20px;\r\n  }\r\n}\r\n</style>"],"mappings":"AAmFA,SAAAA,OAAA,EAAAC,QAAA;AAEA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,QAAA;MACAC,iBAAA;MACAC,UAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IACA,KAAAC,WAAA;IACA,KAAAC,qBAAA;IACA,KAAAC,cAAA;EACA;EACAC,OAAA;IACAH,WAAA,WAAAA,YAAA;MAAA,IAAAI,KAAA;MACA,KAAAC,KAAA;QACAC,GAAA,OAAAC,IAAA,CAAAD,GAAA,CAAAE,IAAA,CAAAC,OAAA;QACAC,MAAA;MACA,GAAAC,IAAA,WAAAC,IAAA;QAAA,IAAAjB,IAAA,GAAAiB,IAAA,CAAAjB,IAAA;QACA,IAAAA,IAAA,IAAAA,IAAA,CAAAkB,IAAA;UACAT,KAAA,CAAAR,QAAA,GAAAD,IAAA,CAAAA,IAAA;UACAmB,OAAA,CAAAC,GAAA,cAAAX,KAAA,CAAAR,QAAA;QACA;UACAQ,KAAA,CAAAY,QAAA,CAAAC,KAAA,CAAAtB,IAAA,CAAAuB,GAAA;QACA;MACA,GAAAC,KAAA,WAAAF,KAAA;QACAH,OAAA,CAAAG,KAAA,cAAAA,KAAA;QACAb,KAAA,CAAAY,QAAA,CAAAC,KAAA;MACA;IACA;IAEA;IACAhB,qBAAA,WAAAA,sBAAA;MAAA,IAAAmB,MAAA;MACA,KAAAf,KAAA;QACAC,GAAA,OAAAC,IAAA,CAAAD,GAAA,CAAAe,UAAA,CAAAC,IAAA;QACAZ,MAAA;QACAa,MAAA;UACAC,IAAA;UACAC,KAAA;QACA;MACA,GAAAd,IAAA,WAAAe,KAAA;QAAA,IAAA/B,IAAA,GAAA+B,KAAA,CAAA/B,IAAA;QACA,IAAAA,IAAA,IAAAA,IAAA,CAAAkB,IAAA;UACAO,MAAA,CAAAvB,iBAAA,GAAAF,IAAA,CAAAA,IAAA,CAAAgC,OAAA,IAAAhC,IAAA,CAAAA,IAAA;QACA;UACAyB,MAAA,CAAAJ,QAAA,CAAAC,KAAA,CAAAtB,IAAA,CAAAuB,GAAA;QACA;MACA,GAAAC,KAAA,WAAAF,KAAA;QACAH,OAAA,CAAAG,KAAA,cAAAA,KAAA;MACA;IACA;IAEA;IACAf,cAAA,WAAAA,eAAA;MAAA,IAAA0B,MAAA;MACA,KAAAvB,KAAA;QACAC,GAAA,OAAAC,IAAA,CAAAD,GAAA,CAAAuB,GAAA,CAAAP,IAAA;QACAZ,MAAA;QACAa,MAAA;UACAC,IAAA;UACAC,KAAA;QACA;MACA,GAAAd,IAAA,WAAAmB,KAAA;QAAA,IAAAnC,IAAA,GAAAmC,KAAA,CAAAnC,IAAA;QACA,IAAAA,IAAA,IAAAA,IAAA