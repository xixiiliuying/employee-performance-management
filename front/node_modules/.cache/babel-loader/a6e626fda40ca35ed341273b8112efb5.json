class=\"center-content\">\r\n      <!-- 左侧个人信息卡片 -->\r\n      <div class=\"left-sidebar\">\r\n        <el-card class=\"user-card\">\r\n          <div class=\"user-avatar-section\">\r\n            <el-avatar\r\n                :size=\"80\"\r\n                :src=\"userInfo.avatar || defaultAvatar\"\r\n                @click=\"showAvatarDialog = true\"\r\n                class=\"user-avatar\"\r\n            >\r\n              {{ userInfo.name ? userInfo.name.charAt(0) : 'U' }}\r\n            </el-avatar>\r\n            <div class=\"user-basic-info\">\r\n              <h3>{{ userInfo.name || '未知用户' }}</h3>\r\n              <p class=\"user-department\">{{ userInfo.departmentName || '未分配部门' }}</p>\r\n              <p class=\"user-job\">{{ userInfo.jobTitle || '未分配岗位' }}</p>\r\n              <el-tag\r\n                  :type=\"userInfo.status === 'active' ? 'success' : 'danger'\"\r\n                  size=\"small\"\r\n              >\r\n                {{ userInfo.status === 'active' ? '在职' : '离职' }}\r\n              </el-tag>\r\n            </div>\r\n          </div>\r\n\r\n          <el-divider></el-divider>\r\n\r\n          <div class=\"user-stats\">\r\n            <div class=\"stat-item\">\r\n              <span class=\"stat-label\">工号</span>\r\n              <span class=\"stat-value\">{{ userInfo.employeeId || 'N/A' }}</span>\r\n            </div>\r\n            <div class=\"stat-item\">\r\n              <span class=\"stat-label\">入职日期</span>\r\n              <span class=\"stat-value\">{{ userInfo.joinDate || 'N/A' }}</span>\r\n            </div>\r\n            <div class=\"stat-item\">\r\n              <span class=\"stat-label\">手机号码</span>\r\n              <span class=\"stat-value\">{{ userInfo.phone || '未设置' }}</span>\r\n            </div>\r\n            <div class=\"stat-item\">\r\n              <span class=\"stat-label\">邮箱</span>\r\n              <span class=\"stat-value\">{{ userInfo.email || '未设置' }}</span>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n\r\n        <!-- 快捷操作 -->\r\n        <el-card class=\"quick-actions-card\">\r\n          <template #header>\r\n            <span>快捷操作</span>\r\n          </template>\r\n          <div class=\"quick-actions\">\r\n            <el-button\r\n                type=\"primary\"\r\n                icon=\"el-icon-edit\"\r\n                @click=\"editProfile\"\r\n                class=\"action-btn\"\r\n            >\r\n              编辑资料\r\n            </el-button>\r\n            <el-button\r\n                icon=\"el-icon-lock\"\r\n                @click=\"changePassword\"\r\n                class=\"action-btn\"\r\n            >\r\n              修改密码\r\n            </el-button>\r\n            <el-button\r\n                icon=\"el-icon-bell\"\r\n                @click=\"notificationSettings\"\r\n                class=\"action-btn\"\r\n            >\r\n              通知设置\r\n            </el-button>\r\n          </div>\r\n        </el-card>\r\n      </div>\r\n\r\n      <!-- 右侧内容区域 -->\r\n      <div class=\"right-content\">\r\n        <!-- 选项卡 -->\r\n        <el-tabs v-model=\"activeTab\" class=\"center-tabs\">\r\n          <!-- 基本信息标签页 -->\r\n          <el-tab-pane label=\"基本信息\" name=\"basic\">\r\n            <BasicInfo\r\n                :user-info=\"userInfo\"\r\n                @edit-profile=\"editProfile\"\r\n            />\r\n          </el-tab-pane>\r\n\r\n          <!-- 安全设置标签页 -->\r\n          <el-tab-pane label=\"安全设置\" name=\"security\">\r\n            <SecuritySettings />\r\n          </el-tab-pane>\r\n\r\n          <!-- 考勤统计标签页 -->\r\n          <el-tab-pane label=\"考勤统计\" name=\"attendance\">\r\n            <AttendanceStats />\r\n          </el-tab-pane>\r\n\r\n          <!-- 薪资信息标签页 -->\r\n          <el-tab-pane label=\"薪资信息\" name=\"salary\">\r\n            <SalaryInfo />\r\n          </el-tab-pane>\r\n\r\n          <!-- 请假记录标签页 -->\r\n          <el-tab-pane label=\"请假记录\" name=\"leave\">\r\n            <LeaveRecords />\r\n          </el-tab-pane>\r\n        </el-tabs>\r\n      </div>\r\n    </div>\r\n\r\n    <!-- 头像上传对话框 -->\r\n    <el-dialog\r\n        title=\"更换头像\"\r\n        v-model=\"showAvatarDialog\"\r\n        width=\"400px\"\r\n    >\r\n      <AvatarUpload\r\n          :current-avatar=\"userInfo.avatar\"\r\n          @upload-success=\"handleAvatarSuccess\"\r\n      />\r\n    </el-dialog>\r\n\r\n    <!-- 编辑资料对话框 -->\r\n    <el-dialog\r\n        title=\"编辑资料\"\r\n        v-model=\"showEditDialog\"\r\n        width=\"600px\"\r\n    >\r\n      <ProfileEditForm\r\n          :user-info=\"userInfo\"\r\n          @update-success=\"handleProfileUpdate\"\r\n          @cancel=\"showEditDialog = false\"\r\n      />\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, onMounted } from 'vue'\r\nimport { ElMessage } from 'element-plus'\r\nimport API from '@/utils/api'\r\nimport BasicInfo from '.staffs/components/BasicInfo.vue'\r\nimport SecuritySettings from '.staffs/components/SecuritySettings.vue'\r\nimport AttendanceStats from '.staffs/components/AttendanceStats.vue'\r\nimport SalaryInfo from '.staffs/components/SalaryInfo.vue'\r\nimport LeaveRecords from '.staffs/components/LeaveRecords.vue'\r\nimport AvatarUpload from '.staffs/components/AvatarUpload.vue'\r\nimport ProfileEditForm from '.staffs/components/ProfileEditForm.vue'\r\n\r\nexport default {\r\n  name: 'Center',\r\n  components: {\r\n    BasicInfo,\r\n    SecuritySettings,\r\n    AttendanceStats,\r\n    SalaryInfo,\r\n    LeaveRecords,\r\n    AvatarUpload,\r\n    ProfileEditForm\r\n  },\r\n  setup() {\r\n    const userInfo = ref({})\r\n    const activeTab = ref('basic')\r\n    const showAvatarDialog = ref(false)\r\n    const showEditDialog = ref(false)\r\n    const defaultAvatar = ref('/default-avatar.png')\r\n\r\n    // 获取用户信息\r\n    const fetchUserInfo = async () => {\r\n      try {\r\n        const { data } = await this.$http.get(API.url.user.session)\r\n        if (data && data.code === 0) {\r\n          userInfo.value = data.data\r\n        } else {\r\n          ElMessage.error(data.msg || '获取用户信息失败')\r\n        }\r\n      } catch (error) {\r\n        console.error('获取用户信息失败:', error)\r\n        ElMessage.error('获取用户信息失败')\r\n      }\r\n    }\r\n\r\n    // 处理头像上传成功\r\n    const handleAvatarSuccess = (avatarUrl) => {\r\n      userInfo.value.avatar = avatarUrl\r\n      showAvatarDialog.value = false\r\n      ElMessage.success('头像更新成功')\r\n    }\r\n\r\n    // 处理资料更新成功\r\n    const handleProfileUpdate = () => {\r\n      showEditDialog.value = false\r\n      fetchUserInfo()\r\n      ElMessage.success('资料更新成功')\r\n    }\r\n\r\n    // 编辑资料\r\n    const editProfile = () => {\r\n      showEditDialog.value = true\r\n    }\r\n\r\n    // 修改密码\r\n    const changePassword = () => {\r\n      activeTab.value = 'security'\r\n    }\r\n\r\n    // 通知设置\r\n    const notificationSettings = () => {\r\n      ElMessage.info('通知设置功能开发中')\r\n    }\r\n\r\n    onMounted(() => {\r\n      fetchUserInfo()\r\n    })\r\n\r\n    return {\r\n      userInfo,\r\n      activeTab,\r\n      showAvatarDialog,\r\n      showEditDialog,\r\n      defaultAvatar,\r\n      fetchUserInfo,\r\n      handleAvatarSuccess,\r\n      handleProfileUpdate,\r\n      editProfile,\r\n      changePassword,\r\n      notificationSettings\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.center-container {\r\n  padding: 20px;\r\n  background-color: #f5f7fa;\r\n  min-height: calc(100vh - 60px);\r\n}\r\n\r\n.page-header {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.page-header h1 {\r\n  margin: 0;\r\n  color: #303133;\r\n  font-size: 24px;\r\n}\r\n\r\n.page-header p {\r\n  margin: 5px 0 0 0;\r\n  color: #909399;\r\n  font-size: 14px;\r\n}\r\n\r\n.center-content {\r\n  display: flex;\r\n  gap: 20px;\r\n}\r\n\r\n.left-sidebar {\r\n  width: 300px;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.right-content {\r\n  flex: 1;\r\n  min-width: 0;\r\n}\r\n\r\n.user-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.user-avatar-section {\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 15px;\r\n}\r\n\r\n.user-avatar {\r\n  cursor: pointer;\r\n  border: 3px solid #e6f7ff;\r\n  transition: all 0.3s;\r\n}\r\n\r\n.user-avatar:hover {\r\n  border-color: #1890ff;\r\n  transform: scale(1.05);\r\n}\r\n\r\n.user-basic-info h3 {\r\n  margin: 0 0 8px 0;\r\n  font-size: 18px;\r\n  color: #303133;\r\n}\r\n\r\n.user-department {\r\n  margin: 0 0 5px 0;\r\n  color: #606266;\r\n  font-size: 14px;\r\n}\r\n\r\n.user-job {\r\n  margin: 0 0 10px 0;\r\n  color: #909399;\r\n  font-size: 13px;\r\n}\r\n\r\n.user-stats {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 12px;\r\n}\r\n\r\n.stat-item {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.stat-label {\r\n  color: #909399;\r\n  font-size: 14px;\r\n}\r\n\r\n.stat-value {\r\n  color: #303133;\r\n  font-weight: 500;\r\n}\r\n\r\n.quick-actions-card {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.quick-actions {\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n}\r\n\r\n.action-btn {\r\n  width: 100%;\r\n  justify-content: flex-start;\r\n}\r\n\r\n.center-tabs {\r\n  background: white;\r\n  border-radius: 8px;\r\n  padding: 20px;\r\n}\r\n\r\n:deep(.el-tabs__header) {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n:deep(.el-tabs__nav-wrap)::after {\r\n  height: 1px;\r\n}\r\n\r\n/* 响应式设计 */\r\n@media (max-width: 768px) {\r\n  .center-content {\r\n    flex-direction: column;\r\n  }\r\n\r\n  .left-sidebar {\r\n    width: 100%;\r\n  }\r\n\r\n  .user-avatar-section {\r\n    flex-direction: column;\r\n    text-align: center;\r\n  }\r\n}\r\n</style>"],"mappings":";;AAuJA,SAAAA,GAAA,EAAAC,SAAA;AACA,SAAAC,SAAA;AACA,OAAAC,GAAA;AACA,OAAAC,SAAA;AACA,OAAAC,gBAAA;AACA,OAAAC,eAAA;AACA,OAAAC,UAAA;AACA,OAAAC,YAAA;AACA,OAAAC,YAAA;AACA,OAAAC,eAAA;AAEA;EACAC,IAAA;EACAC,UAAA;IACAR,SAAA,EAAAA,SAAA;IACAC,gBAAA,EAAAA,gBAAA;IACAC,eAAA,EAAAA,eAAA;IACAC,UAAA,EAAAA,UAAA;IACAC,YAAA,EAAAA,YAAA;IACAC,YAAA,EAAAA,YAAA;IACAC,eAAA,EAAAA;EACA;EACAG,KAAA,WAAAA,MAAA;IAAA