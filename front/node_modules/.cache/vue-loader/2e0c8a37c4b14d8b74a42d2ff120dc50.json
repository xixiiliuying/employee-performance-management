{"remainingRequest":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\project\\java_project\\T021\\front\\src\\view\\staffs\\component\\ProfileEditForm.vue?vue&type=script&setup=true&lang=ts","dependencies":[{"path":"E:\\project\\java_project\\T021\\front\\src\\view\\staffs\\component\\ProfileEditForm.vue","mtime":1763022634676},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1762233496489}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"file":null,"sources":["ProfileEditForm.vue"],"sourcesContent":["<script setup lang=\"ts\">\r\nimport { ref, reactive, onMounted } from 'vue'\r\nimport { ElMessage, ElMessageBox } from 'element-plus'\r\nimport type { FormInstance, FormRules } from 'element-plus'\r\nimport API from '@/utils/api'\r\n\r\ninterface Department {\r\n  id: number\r\n  dname: string\r\n}\r\n\r\ninterface Job {\r\n  id: number\r\n  jname: string\r\n}\r\n\r\ninterface UserInfo {\r\n  id?: number\r\n  sname: string\r\n  sid: string\r\n  deptId: number | null\r\n  jobId: number | null\r\n  phone: string\r\n  email: string\r\n  hireDate: string\r\n  status: string\r\n  avatar?: string\r\n}\r\n\r\n// Props\r\nconst props = defineProps<{\r\n  userInfo: UserInfo\r\n  departmentList: Department[]\r\n  jobList: Job[]\r\n}>()\r\n\r\n// Emits\r\nconst emit = defineEmits<{\r\n  'update-success': []\r\n  'cancel': []\r\n}>()\r\n\r\n// Refs\r\nconst formRef = ref<FormInstance>()\r\nconst loading = ref(false)\r\n\r\n// Form data\r\nconst formData = reactive<UserInfo>({\r\n  sname: '',\r\n  sid: '',\r\n  deptId: null,\r\n  jobId: null,\r\n  phone: '',\r\n  email: '',\r\n  hireDate: '',\r\n  status: 'active'\r\n})\r\n\r\n// Form rules\r\nconst formRules = reactive<FormRules<UserInfo>>({\r\n  sname: [\r\n    { required: true, message: '请输入姓名', trigger: 'blur' },\r\n    { min: 2, max: 10, message: '姓名长度在 2 到 10 个字符', trigger: 'blur' }\r\n  ],\r\n  sid: [\r\n    { required: true, message: '请输入工号', trigger: 'blur' }\r\n  ],\r\n  deptId: [\r\n    { required: true, message: '请选择部门', trigger: 'change' }\r\n  ],\r\n  jobId: [\r\n    { required: true, message: '请选择岗位', trigger: 'change' }\r\n  ],\r\n  phone: [\r\n    { required: true, message: '请输入手机号码', trigger: 'blur' },\r\n    { pattern: /^1[3-9]\\d{9}$/, message: '请输入正确的手机号码', trigger: 'blur' }\r\n  ],\r\n  email: [\r\n    { required: true, message: '请输入邮箱', trigger: 'blur' },\r\n    { type: 'email', message: '请输入正确的邮箱地址', trigger: 'blur' }\r\n  ],\r\n  hireDate: [\r\n    { required: true, message: '请选择入职日期', trigger: 'change' }\r\n  ]\r\n})\r\n\r\n// Initialize form data\r\nconst initFormData = () => {\r\n  Object.assign(formData, {\r\n    sname: props.userInfo.sname || '',\r\n    sid: props.userInfo.sid || '',\r\n    deptId: props.userInfo.deptId || null,\r\n    jobId: props.userInfo.jobId || null,\r\n    phone: props.userInfo.phone || '',\r\n    email: props.userInfo.email || '',\r\n    hireDate: props.userInfo.hireDate || '',\r\n    status: props.userInfo.status || 'active'\r\n  })\r\n}\r\n\r\n// Submit form\r\nconst submitForm = async () => {\r\n  if (!formRef.value) return\r\n\r\n  try {\r\n    const valid = await formRef.value.validate()\r\n    if (!valid) return\r\n\r\n    loading.value = true\r\n\r\n    // 使用您的API接口更新用户信息\r\n    const response = await fetch(API.baseURL + API.url.user.update, {\r\n      method: 'POST',\r\n      headers: {\r\n        'Content-Type': 'application/json',\r\n        'Authorization': `Bearer ${localStorage.getItem('token')}`\r\n      },\r\n      body: JSON.stringify({\r\n        id: props.userInfo.id,\r\n        sname: formData.sname,\r\n        deptId: formData.deptId,\r\n        jobId: formData.jobId,\r\n        phone: formData.phone,\r\n        email: formData.email\r\n        // 注意：工号和入职日期通常不允许修改，所以不传这些字段\r\n      })\r\n    })\r\n\r\n    if (!response.ok) {\r\n      throw new Error(`HTTP error! status: ${response.status}`)\r\n    }\r\n\r\n    const result = await response.json()\r\n\r\n    if (result.code === 0) {\r\n      ElMessage.success('资料更新成功')\r\n      emit('update-success')\r\n    } else {\r\n      ElMessage.error(result.msg || '更新失败')\r\n    }\r\n  } catch (error) {\r\n    console.error('更新用户信息失败:', error)\r\n    ElMessage.error('更新失败，请重试')\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\n// 使用 $http 的版本（如果您的项目使用了封装的 http 请求）\r\nconst submitFormWithHttp = async () => {\r\n  if (!formRef.value) return\r\n\r\n  try {\r\n    const valid = await formRef.value.validate()\r\n    if (!valid) return\r\n\r\n    loading.value = true\r\n\r\n    // 如果您的项目使用了封装的 $http\r\n    const { data: result } = await $http.post(API.url.user.update, {\r\n      id: props.userInfo.id,\r\n      sname: formData.sname,\r\n      deptId: formData.deptId,\r\n      jobId: formData.jobId,\r\n      phone: formData.phone,\r\n      email: formData.email\r\n    })\r\n\r\n    if (result.code === 0) {\r\n      ElMessage.success('资料更新成功')\r\n      emit('update-success')\r\n    } else {\r\n      ElMessage.error(result.msg || '更新失败')\r\n    }\r\n  } catch (error) {\r\n    console.error('更新用户信息失败:', error)\r\n    ElMessage.error('更新失败，请重试')\r\n  } finally {\r\n    loading.value = false\r\n  }\r\n}\r\n\r\n// Cancel edit\r\nconst cancelEdit = () => {\r\n  ElMessageBox.confirm('确定取消编辑吗？所有未保存的更改将会丢失。', '提示', {\r\n    confirmButtonText: '确定',\r\n    cancelButtonText: '取消',\r\n    type: 'warning'\r\n  }).then(() => {\r\n    initFormData()\r\n    emit('cancel')\r\n  }).catch(() => {\r\n    // 用户点击取消，不做任何操作\r\n  })\r\n}\r\n\r\n// Reset form\r\nconst resetForm = () => {\r\n  if (formRef.value) {\r\n    formRef.value.resetFields()\r\n    initFormData()\r\n  }\r\n}\r\n\r\n// Format date for display\r\nconst formatDate = (dateString: string) => {\r\n  if (!dateString) return ''\r\n  const date = new Date(dateString)\r\n  return date.toLocaleDateString('zh-CN')\r\n}\r\n\r\n// Watch for userInfo changes\r\nonMounted(() => {\r\n  initFormData()\r\n})\r\n</script>\r\n\r\n<template>\r\n  <div class=\"profile-edit-form\">\r\n    <el-form\r\n        ref=\"formRef\"\r\n        :model=\"formData\"\r\n        :rules=\"formRules\"\r\n        label-width=\"100px\"\r\n        label-position=\"right\"\r\n    >\r\n      <!-- 基本信息 -->\r\n      <div class=\"form-section\">\r\n        <h3 class=\"section-title\">基本信息</h3>\r\n        <div class=\"form-row\">\r\n          <el-form-item label=\"姓名\" prop=\"sname\">\r\n            <el-input\r\n                v-model=\"formData.sname\"\r\n                placeholder=\"请输入姓名\"\r\n                maxlength=\"10\"\r\n                show-word-limit\r\n            />\r\n          </el-form-item>\r\n\r\n          <el-form-item label=\"工号\" prop=\"sid\">\r\n            <el-input\r\n                v-model=\"formData.sid\"\r\n                placeholder=\"请输入工号\"\r\n                disabled\r\n            />\r\n            <div class=\"field-tip\">工号不可修改</div>\r\n          </el-form-item>\r\n        </div>\r\n\r\n        <div class=\"form-row\">\r\n          <el-form-item label=\"部门\" prop=\"deptId\">\r\n            <el-select\r\n                v-model=\"formData.deptId\"\r\n                placeholder=\"请选择部门\"\r\n                style=\"width: 100%\"\r\n                clearable\r\n                filterable\r\n            >\r\n              <el-option\r\n                  v-for=\"dept in departmentList\"\r\n                  :key=\"dept.id\"\r\n                  :label=\"dept.dname\"\r\n                  :value=\"dept.id\"\r\n              />\r\n            </el-select>\r\n          </el-form-item>\r\n\r\n          <el-form-item label=\"岗位\" prop=\"jobId\">\r\n            <el-select\r\n                v-model=\"formData.jobId\"\r\n                placeholder=\"请选择岗位\"\r\n                style=\"width: 100%\"\r\n                clearable\r\n                filterable\r\n            >\r\n              <el-option\r\n                  v-for=\"job in jobList\"\r\n                  :key=\"job.id\"\r\n                  :label=\"job.jname\"\r\n                  :value=\"job.id\"\r\n              />\r\n            </el-select>\r\n          </el-form-item>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 联系信息 -->\r\n      <div class=\"form-section\">\r\n        <h3 class=\"section-title\">联系信息</h3>\r\n        <div class=\"form-row\">\r\n          <el-form-item label=\"手机号码\" prop=\"phone\">\r\n            <el-input\r\n                v-model=\"formData.phone\"\r\n                placeholder=\"请输入手机号码\"\r\n                maxlength=\"11\"\r\n            />\r\n          </el-form-item>\r\n\r\n          <el-form-item label=\"邮箱\" prop=\"email\">\r\n            <el-input\r\n                v-model=\"formData.email\"\r\n                placeholder=\"请输入邮箱地址\"\r\n                type=\"email\"\r\n            />\r\n          </el-form-item>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 入职信息 -->\r\n      <div class=\"form-section\">\r\n        <h3 class=\"section-title\">入职信息</h3>\r\n        <div class=\"form-row\">\r\n          <el-form-item label=\"入职日期\">\r\n            <el-date-picker\r\n                v-model=\"formData.hireDate\"\r\n                type=\"date\"\r\n                placeholder=\"选择入职日期\"\r\n                style=\"width: 100%\"\r\n                format=\"YYYY-MM-DD\"\r\n                value-format=\"YYYY-MM-DD\"\r\n                disabled\r\n            />\r\n            <div class=\"field-tip\">入职日期不可修改</div>\r\n          </el-form-item>\r\n\r\n          <el-form-item label=\"员工状态\">\r\n            <el-tag :type=\"formData.status === 'active' ? 'success' : 'danger'\">\r\n              {{ formData.status === 'active' ? '在职' : '离职' }}\r\n            </el-tag>\r\n            <div class=\"field-tip\">状态由系统管理</div>\r\n          </el-form-item>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 操作按钮 -->\r\n      <div class=\"form-actions\">\r\n        <el-button @click=\"cancelEdit\" :disabled=\"loading\">\r\n          取消\r\n        </el-button>\r\n        <el-button @click=\"resetForm\" :disabled=\"loading\">\r\n          重置\r\n        </el-button>\r\n        <el-button\r\n            type=\"primary\"\r\n            :loading=\"loading\"\r\n            @click=\"submitForm\"\r\n        >\r\n          {{ loading ? '保存中...' : '保存更改' }}\r\n        </el-button>\r\n      </div>\r\n    </el-form>\r\n  </div>\r\n</template>\r\n\r\n<style scoped lang=\"scss\">\r\n.profile-edit-form {\r\n  padding: 0 20px;\r\n\r\n  .form-section {\r\n    margin-bottom: 24px;\r\n    padding: 20px;\r\n    background: #f8f9fa;\r\n    border-radius: 8px;\r\n\r\n    .section-title {\r\n      margin: 0 0 16px 0;\r\n      font-size: 16px;\r\n      color: #303133;\r\n      font-weight: 600;\r\n      padding-bottom: 8px;\r\n      border-bottom: 1px solid #e0e0e0;\r\n    }\r\n  }\r\n\r\n  .form-row {\r\n    display: grid;\r\n    grid-template-columns: 1fr 1fr;\r\n    gap: 20px;\r\n\r\n    &:not(:last-child) {\r\n      margin-bottom: 16px;\r\n    }\r\n  }\r\n\r\n  .field-tip {\r\n    font-size: 12px;\r\n    color: #909399;\r\n    margin-top: 4px;\r\n  }\r\n\r\n  .form-actions {\r\n    display: flex;\r\n    justify-content: center;\r\n    gap: 12px;\r\n    margin-top: 32px;\r\n    padding-top: 20px;\r\n    border-top: 1px solid #e0e0e0;\r\n\r\n    .el-button {\r\n      min-width: 100px;\r\n    }\r\n  }\r\n}\r\n\r\n// 响应式设计\r\n@media (max-width: 768px) {\r\n  .profile-edit-form {\r\n    padding: 0 10px;\r\n\r\n    .form-row {\r\n      grid-template-columns: 1fr;\r\n      gap: 0;\r\n    }\r\n\r\n    .form-actions {\r\n      flex-direction: column;\r\n\r\n      .el-button {\r\n        width: 100%;\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 表单样式优化\r\n:deep(.el-form-item__label) {\r\n  font-weight: 500;\r\n  color: #606266;\r\n}\r\n\r\n:deep(.el-input__inner) {\r\n  border-radius: 