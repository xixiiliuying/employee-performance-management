{"remainingRequest":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\project\\java_project\\T021\\front\\src\\views\\update-password.vue?vue&type=style&index=0&id=467fc075&lang=scss&scoped=true","dependencies":[{"path":"E:\\project\\java_project\\T021\\front\\src\\views\\update-password.vue","mtime":1762836342607},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\css-loader\\dist\\cjs.js","mtime":1762233495618},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1762233498059},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\postcss-loader\\src\\index.js","mtime":1762233495756},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1762234960396},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1762233496489}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["update-password.vue"],"names":[],"mappings":";AAwMA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA","file":"update-password.vue","sourceRoot":"src/views","sourcesContent":["<template>\r\n  <div>\r\n    <el-form class=\"detail-form-content\" ref=\"ruleForm\" :model=\"ruleForm\" label-width=\"100px\">\r\n      <el-row>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"员工号\" prop=\"sid\">\r\n            <el-input v-model=\"ruleForm.sid\" readonly placeholder=\"员工号\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"员工姓名\" prop=\"sname\">\r\n            <el-input v-model=\"ruleForm.sname\" placeholder=\"员工姓名\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"性别\" prop=\"gender\">\r\n            <el-select v-model=\"ruleForm.gender\" placeholder=\"请选择性别\">\r\n              <el-option label=\"男\" value=\"男\"></el-option>\r\n              <el-option label=\"女\" value=\"女\"></el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"角色\" prop=\"role\">\r\n            <el-input v-model=\"ruleForm.role\" readonly placeholder=\"角色\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"部门\" prop=\"deptId\">\r\n            <el-select v-model=\"ruleForm.deptId\" placeholder=\"请选择部门\" clearable>\r\n              <el-option\r\n                  v-for=\"item in departmentOptions\"\r\n                  :key=\"item.id\"\r\n                  :label=\"item.dname\"\r\n                  :value=\"item.id\">\r\n              </el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"岗位\" prop=\"jobId\">\r\n            <el-select v-model=\"ruleForm.jobId\" placeholder=\"请选择岗位\" clearable>\r\n              <el-option\r\n                  v-for=\"item in jobOptions\"\r\n                  :key=\"item.id\"\r\n                  :label=\"item.jname\"\r\n                  :value=\"item.id\">\r\n              </el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"联系电话\" prop=\"phone\">\r\n            <el-input v-model=\"ruleForm.phone\" placeholder=\"联系电话\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"邮箱\" prop=\"email\">\r\n            <el-input v-model=\"ruleForm.email\" placeholder=\"邮箱\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"入职日期\" prop=\"hireDate\">\r\n            <el-date-picker\r\n                v-model=\"ruleForm.hireDate\"\r\n                type=\"date\"\r\n                placeholder=\"选择入职日期\"\r\n                value-format=\"yyyy-MM-dd\"\r\n                readonly>\r\n            </el-date-picker>\r\n          </el-form-item>\r\n        </el-col>\r\n        <el-col :span=\"24\">\r\n          <el-form-item>\r\n            <el-button type=\"primary\" @click=\"onUpdateHandler\">修 改</el-button>\r\n          </el-form-item>\r\n        </el-col>\r\n      </el-row>\r\n    </el-form>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { isEmail, isMobile } from \"@/utils/validate\";\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      ruleForm: {},\r\n      departmentOptions: [],\r\n      jobOptions: []\r\n    };\r\n  },\r\n  mounted() {\r\n    this.getUserInfo();\r\n    this.loadDepartmentOptions();\r\n    this.loadJobOptions();\r\n  },\r\n  methods: {\r\n    getUserInfo() {\r\n      this.$http({\r\n        url: this.$api.url.user.session,\r\n        method: \"get\"\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.ruleForm = data.data;\r\n          console.log('获取用户信息成功:', this.ruleForm);\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('获取用户信息失败:', error);\r\n        this.$message.error('获取用户信息失败');\r\n      });\r\n    },\r\n\r\n    // 加载部门选项\r\n    loadDepartmentOptions() {\r\n      this.$http({\r\n        url: this.$api.url.department.list,\r\n        method: \"get\",\r\n        params: {\r\n          page: 1,\r\n          limit: 100\r\n        }\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.departmentOptions = data.data.records || data.data;\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('获取部门选项失败:', error);\r\n      });\r\n    },\r\n\r\n    // 加载岗位选项\r\n    loadJobOptions() {\r\n      this.$http({\r\n        url: this.$api.url.job.list,\r\n        method: \"get\",\r\n        params: {\r\n          page: 1,\r\n          limit: 100\r\n        }\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.jobOptions = data.data.records || data.data;\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('获取岗位选项失败:', error);\r\n      });\r\n    },\r\n\r\n    onUpdateHandler() {\r\n      // 表单验证\r\n      if(!this.ruleForm.sid){\r\n        this.$message.error('员工号不能为空');\r\n        return\r\n      }\r\n      if(!this.ruleForm.sname){\r\n        this.$message.error('员工姓名不能为空');\r\n        return\r\n      }\r\n      if(this.ruleForm.phone && (!isMobile(this.ruleForm.phone))){\r\n        this.$message.error(`联系电话应输入手机格式`);\r\n        return\r\n      }\r\n      if(this.ruleForm.email && (!isEmail(this.ruleForm.email))){\r\n        this.$message.error(`邮箱应输入邮箱格式`);\r\n        return\r\n      }\r\n\r\n      // 更新用户信息\r\n      this.$http({\r\n        url: this.$api.url.user.update,\r\n        method: \"post\",\r\n        data: this.ruleForm\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.$message({\r\n            message: \"修改信息成功\",\r\n            type: \"success\",\r\n            duration: 1500\r\n          });\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('更新用户信息失败:', error);\r\n        this.$message.error('更新失败，请稍后重试');\r\n      });\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.detail-form-content {\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n  padding: 20px;\r\n\r\n  .el-row {\r\n    margin-bottom: 20px;\r\n  }\r\n\r\n  .el-col {\r\n    padding: 0 10px;\r\n  }\r\n\r\n  .el-form-item {\r\n    margin-bottom: 20px;\r\n\r\n    .el-input, .el-select, .el-date-picker {\r\n      width: 100%;\r\n    }\r\n  }\r\n\r\n  .el-button {\r\n    width: 200px;\r\n    margin-top: 20px;\r\n  }\r\n}\r\n</style>"]}]}