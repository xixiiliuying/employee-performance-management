{"remainingRequest":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\project\\java_project\\T021\\front\\src\\view\\staffs\\IndexPage.vue?vue&type=style&index=1&id=9cf9a4f4&scoped=true&lang=css","dependencies":[{"path":"E:\\project\\java_project\\T021\\front\\src\\view\\staffs\\IndexPage.vue","mtime":1762914654493},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\css-loader\\dist\\cjs.js","mtime":1762233495618},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1762233498059},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\postcss-loader\\src\\index.js","mtime":1762233495756},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1762233496489}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["IndexPage.vue"],"names":[],"mappings":";AA6dA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA","file":"IndexPage.vue","sourceRoot":"src/view/staffs","sourcesContent":["<template>\r\n  <div class=\"staff-dashboard\">\r\n    <!-- 页面标题 -->\r\n    <div class=\"page-header\">\r\n      <h1>员工工作台</h1>\r\n      <p>欢迎回来，{{ userInfo.name || '同事' }}！今天是 {{ currentDate }}</p>\r\n    </div>\r\n\r\n    <!-- 主要功能模块 -->\r\n    <el-row :gutter=\"20\" class=\"main-modules\">\r\n      <!-- 考勤模块 -->\r\n      <el-col :span=\"8\">\r\n        <el-card class=\"module-card attendance-module\" shadow=\"hover\" @click.native=\"$router.push('/index/attendance')\">\r\n          <div class=\"module-header\">\r\n            <div class=\"module-icon\">\r\n              <i class=\"el-icon-time\"></i>\r\n            </div>\r\n            <div class=\"module-title\">\r\n              <h3>考勤打卡</h3>\r\n              <p>今日考勤状态</p>\r\n            </div>\r\n          </div>\r\n          <div class=\"module-content\">\r\n            <div class=\"attendance-status\">\r\n              <el-tag :type=\"todayStatus.type\" size=\"medium\">{{ todayStatus.text }}</el-tag>\r\n            </div>\r\n            <div class=\"attendance-times\">\r\n              <div class=\"time-item\">\r\n                <span class=\"time-label\">上班</span>\r\n                <span class=\"time-value\">{{ todayAttendance.clockInTime || '--:--' }}</span>\r\n              </div>\r\n              <div class=\"time-item\">\r\n                <span class=\"time-label\">下班</span>\r\n                <span class=\"time-value\">{{ todayAttendance.clockOutTime || '--:--' }}</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"module-footer\">\r\n            <span class=\"action-text\">点击查看考勤详情</span>\r\n            <i class=\"el-icon-arrow-right\"></i>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n\r\n      <!-- 请假模块 -->\r\n      <el-col :span=\"8\">\r\n        <el-card class=\"module-card leave-module\" shadow=\"hover\" @click.native=\"$router.push('/index/leave')\">\r\n          <div class=\"module-header\">\r\n            <div class=\"module-icon\">\r\n              <i class=\"el-icon-date\"></i>\r\n            </div>\r\n            <div class=\"module-title\">\r\n              <h3>请假管理</h3>\r\n              <p>假期余额与申请</p>\r\n            </div>\r\n          </div>\r\n          <div class=\"module-content\">\r\n            <div class=\"leave-stats\">\r\n              <div class=\"stat-item\">\r\n                <div class=\"stat-value\">{{ leaveStats.remainingDays || 0 }}</div>\r\n                <div class=\"stat-label\">剩余假期(天)</div>\r\n              </div>\r\n              <div class=\"stat-item\">\r\n                <div class=\"stat-value\">{{ leaveStats.pendingCount || 0 }}</div>\r\n                <div class=\"stat-label\">待审批</div>\r\n              </div>\r\n            </div>\r\n            <div class=\"leave-types\">\r\n              <el-tag size=\"small\" type=\"success\">年假</el-tag>\r\n              <el-tag size=\"small\" type=\"warning\">事假</el-tag>\r\n              <el-tag size=\"small\" type=\"danger\">病假</el-tag>\r\n            </div>\r\n          </div>\r\n          <div class=\"module-footer\">\r\n            <span class=\"action-text\">点击申请请假</span>\r\n            <i class=\"el-icon-arrow-right\"></i>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n\r\n      <!-- 薪资模块 -->\r\n      <el-col :span=\"8\">\r\n        <el-card class=\"module-card salary-module\" shadow=\"hover\" @click.native=\"$router.push('/index/salary')\">\r\n          <div class=\"module-header\">\r\n            <div class=\"module-icon\">\r\n              <i class=\"el-icon-money\"></i>\r\n            </div>\r\n            <div class=\"module-title\">\r\n              <h3>薪资查询</h3>\r\n              <p>工资明细与统计</p>\r\n            </div>\r\n          </div>\r\n          <div class=\"module-content\">\r\n            <div class=\"salary-preview\">\r\n              <div class=\"salary-amount\">\r\n                <span class=\"currency\">¥</span>\r\n                <span class=\"amount\">{{ latestSalary?.totalAmount ? formatSalary(latestSalary.totalAmount) : '0' }}</span>\r\n              </div>\r\n              <div class=\"salary-period\" v-if=\"latestSalary\">\r\n                最近发放：{{ formatSalaryPeriod(latestSalary.salaryMonth) }}\r\n              </div>\r\n              <div class=\"salary-period\" v-else>\r\n                暂无薪资记录\r\n              </div>\r\n            </div>\r\n            <div class=\"salary-detail\" v-if=\"latestSalary\">\r\n              <div class=\"detail-item\">\r\n                <span>基本工资</span>\r\n                <span>¥{{ formatSalary(latestSalary.baseSalary) }}</span>\r\n              </div>\r\n              <div class=\"detail-item\">\r\n                <span>绩效奖金</span>\r\n                <span>¥{{ formatSalary(latestSalary.performanceBonus) }}</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"module-footer\">\r\n            <span class=\"action-text\">点击查看薪资详情</span>\r\n            <i class=\"el-icon-arrow-right\"></i>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <!-- 底部信息区域 -->\r\n    <el-row :gutter=\"20\" class=\"bottom-section\">\r\n      <!-- 最近公告 -->\r\n      <el-col :span=\"12\">\r\n        <el-card class=\"info-card\" shadow=\"never\">\r\n          <template #header>\r\n            <div class=\"card-header\">\r\n              <span>最新公告</span>\r\n              <el-button type=\"text\" @click=\"$router.push('/index/notice')\">查看全部</el-button>\r\n            </div>\r\n          </template>\r\n          <div class=\"notice-list\">\r\n            <div\r\n                v-for=\"notice in recentNotices\"\r\n                :key=\"notice.id\"\r\n                class=\"notice-item\"\r\n                @click=\"viewNoticeDetail(notice)\"\r\n            >\r\n              <div class=\"notice-badge\">\r\n                <i class=\"el-icon-chat-dot-round\"></i>\r\n              </div>\r\n              <div class=\"notice-content\">\r\n                <div class=\"notice-title\">{{ notice.title }}</div>\r\n                <div class=\"notice-meta\">\r\n                  <span class=\"notice-time\">{{ formatDate(notice.publishDate) }}</span>\r\n                  <el-tag v-if=\"isNewNotice(notice.publishDate)\" type=\"danger\" size=\"mini\">新</el-tag>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div v-if=\"recentNotices.length === 0\" class=\"empty-state\">\r\n            <i class=\"el-icon-bell\"></i>\r\n            <p>暂无新公告</p>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n\r\n      <!-- 个人信息 -->\r\n      <el-col :span=\"12\">\r\n        <el-card class=\"info-card\" shadow=\"never\">\r\n          <template #header>\r\n            <div class=\"card-header\">\r\n              <span>个人信息</span>\r\n              <el-button type=\"text\" @click=\"$router.push('/index/center')\">编辑信息</el-button>\r\n            </div>\r\n          </template>\r\n          <div class=\"user-profile\">\r\n            <div class=\"avatar-section\">\r\n              <el-avatar :size=\"60\" :src=\"userInfo.avatar\" icon=\"el-icon-user-solid\"></el-avatar>\r\n              <div class=\"user-basic\">\r\n                <div class=\"user-name\">{{ userInfo.name || '未设置' }}</div>\r\n                <div class=\"user-position\">{{ userInfo.position || '员工' }}</div>\r\n              </div>\r\n            </div>\r\n            <div class=\"user-details\">\r\n              <div class=\"detail-row\">\r\n                <i class=\"el-icon-office-building\"></i>\r\n                <span>部门：{{ userInfo.departmentName || userInfo.department || '未设置' }}</span>\r\n              </div>\r\n              <div class=\"detail-row\">\r\n                <i class=\"el-icon-mobile-phone\"></i>\r\n                <span>电话：{{ userInfo.phone || '未设置' }}</span>\r\n              </div>\r\n              <div class=\"detail-row\">\r\n                <i class=\"el-icon-date\"></i>\r\n                <span>入职：{{ formatDate(userInfo.entryDate) || '未设置' }}</span>\r\n              </div>\r\n              <div class=\"detail-row\">\r\n                <i class=\"el-icon-location-outline\"></i>\r\n                <span>本月出勤：{{ attendanceStats.workDays || 0 }} 天</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'StaffIndexPage',\r\n  data() {\r\n    return {\r\n      // 统计数据\r\n      attendanceStats: {\r\n        workDays: 0,\r\n        lateCount: 0,\r\n        earlyLeaveCount: 0\r\n      },\r\n      leaveStats: {\r\n        remainingDays: 0,\r\n        pendingCount: 0,\r\n        usedDays: 0\r\n      },\r\n      // 今日考勤\r\n      todayAttendance: {\r\n        clockInTime: '',\r\n        clockOutTime: '',\r\n        status: ''\r\n      },\r\n      todayStatus: {\r\n        type: 'warning',\r\n        text: '未打卡'\r\n      },\r\n      // 最新公告\r\n      recentNotices: [],\r\n      // 用户信息\r\n      userInfo: {},\r\n      // 最新薪资\r\n      latestSalary: null,\r\n      currentDate: ''\r\n    }\r\n  },\r\n  mounted() {\r\n    this.setCurrentDate();\r\n    this.loadUserInfo();\r\n    this.loadDashboardData();\r\n  },\r\n  methods: {\r\n    // 设置当前日期\r\n    setCurrentDate() {\r\n      const now = new Date();\r\n      const options = { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' };\r\n      this.currentDate = now.toLocaleDateString('zh-CN', options);\r\n    },\r\n\r\n    // 加载用户信息\r\n    async loadUserInfo() {\r\n      try {\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.user.session,\r\n          method: 'get'\r\n        });\r\n\r\n        if (data && data.code === 0) {\r\n          this.userInfo = data.data;\r\n        } else {\r\n          this.$message.error('获取用户信息失败');\r\n        }\r\n      } catch (error) {\r\n        console.error('获取用户信息失败:', error);\r\n        this.$message.error('获取用户信息失败');\r\n      }\r\n    },\r\n\r\n    // 加载仪表盘数据\r\n    async loadDashboardData() {\r\n      await Promise.all([\r\n        this.loadTodayAttendance(),\r\n        this.loadAttendanceStatistics(),\r\n        this.loadLeaveStatistics(),\r\n        this.loadLatestSalary(),\r\n        this.loadRecentNotices()\r\n      ]);\r\n    },\r\n\r\n    // 加载今日考勤\r\n    async loadTodayAttendance() {\r\n      try {\r\n        const today = new Date().toISOString().split('T')[0];\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.attendance.myRecords,\r\n          method: 'get',\r\n          params: { date: today }\r\n        });\r\n\r\n        if (data && data.code === 0) {\r\n          const records = data.data || [];\r\n          const todayRecord = records.find(record => record.workDate === today);\r\n\r\n          if (todayRecord) {\r\n            this.todayAttendance = {\r\n              clockInTime: todayRecord.clockInTime,\r\n              clockOutTime: todayRecord.clockOutTime,\r\n              status: todayRecord.status\r\n            };\r\n\r\n            // 更新考勤状态显示\r\n            if (todayRecord.clockInTime && todayRecord.clockOutTime) {\r\n              this.todayStatus = { type: 'success', text: '已完成打卡' };\r\n            } else if (todayRecord.clockInTime) {\r\n              this.todayStatus = { type: 'warning', text: '已上班打卡' };\r\n            } else {\r\n              this.todayStatus = { type: 'danger', text: '未打卡' };\r\n            }\r\n          }\r\n        }\r\n      } catch (error) {\r\n        console.error('获取今日考勤失败:', error);\r\n      }\r\n    },\r\n\r\n    // 加载考勤统计\r\n    async loadAttendanceStatistics() {\r\n      try {\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.attendance.myStatistics,\r\n          method: 'get'\r\n        });\r\n\r\n        if (data && data.code === 0) {\r\n          this.attendanceStats = data.data || {};\r\n        }\r\n      } catch (error) {\r\n        console.error('获取考勤统计失败:', error);\r\n      }\r\n    },\r\n\r\n    // 加载请假统计\r\n    async loadLeaveStatistics() {\r\n      try {\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.leave.myApplications,\r\n          method: 'get'\r\n        });\r\n\r\n        if (data && data.code === 0) {\r\n          const applications = data.data || [];\r\n\r\n          // 计算待审批数量\r\n          const pendingCount = applications.filter(app =>\r\n              app.status === 'PENDING' || app.status === '0'\r\n          ).length;\r\n\r\n          // 这里可以根据实际情况计算剩余假期天数\r\n          // 假设每年有10天年假\r\n          const totalAnnualLeave = 10;\r\n          const usedDays = applications\r\n              .filter(app => (app.status === 'APPROVED' || app.status === '1') && app.leaveType === 'ANNUAL')\r\n              .reduce((sum, app) => sum + (app.days || 0), 0);\r\n\r\n          this.leaveStats = {\r\n            pendingCount,\r\n            remainingDays: Math.max(0, totalAnnualLeave - usedDays),\r\n            usedDays\r\n          };\r\n        }\r\n      } catch (error) {\r\n        console.error('获取请假统计失败:', error);\r\n      }\r\n    },\r\n\r\n    // 加载最新薪资\r\n    async loadLatestSalary() {\r\n      try {\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.salary.mySalary,\r\n          method: 'get',\r\n          params: { page: 1, limit: 1 }\r\n        });\r\n\r\n        if (data && data.code === 0 && data.data && data.data.length > 0) {\r\n          this.latestSalary = data.data[0];\r\n        }\r\n      } catch (error) {\r\n        console.error('获取薪资信息失败:', error);\r\n      }\r\n    },\r\n\r\n    // 加载最新公告\r\n    async loadRecentNotices() {\r\n      try {\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.notice.latest,\r\n          method: 'get',\r\n          params: { count: 5 }\r\n        });\r\n\r\n        if (data && data.code === 0) {\r\n          this.recentNotices = data.data || [];\r\n        }\r\n      } catch (error) {\r\n        console.error('获取最新公告失败:', error);\r\n      }\r\n    },\r\n\r\n    // 查看公告详情\r\n    viewNoticeDetail(notice) {\r\n      this.$router.push({\r\n        path: '/index/notice/detail',\r\n        query: { id: notice.id }\r\n      });\r\n    },\r\n\r\n    // 格式化薪资显示\r\n    formatSalary(amount) {\r\n      if (!amount) return '0';\r\n      return Number(amount).toLocaleString('zh-CN');\r\n    },\r\n\r\n    // 格式化薪资期间\r\n    formatSalaryPeriod(period) {\r\n      if (!period) return '';\r\n      return period.replace(/(\\d{4})(\\d{2})/, '$1年$2月');\r\n    },\r\n\r\n    // 格式化日期\r\n    formatDate(date) {\r\n      if (!date) return '';\r\n      try {\r\n        const dateObj = new Date(date);\r\n        return dateObj.toLocaleDateString('zh-CN');\r\n      } catch (error) {\r\n        return date;\r\n      }\r\n    },\r\n\r\n    // 判断是否为新公告（7天内）\r\n    isNewNotice(publishDate) {\r\n      if (!publishDate) return false;\r\n      try {\r\n        const publish = new Date(publishDate);\r\n        const now = new Date();\r\n        const diffTime = now.getTime() - publish.getTime();\r\n        const diffDays = diffTime / (1000 * 60 * 60 * 24);\r\n        return diffDays <= 7;\r\n      } catch (error) {\r\n        return false;\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n/* 样式保持不变，使用原有的CSS */\r\n.staff-dashboard {\r\n  padding: 20px;\r\n  background-color: #f5f7fa;\r\n  min-height: calc(100vh - 60px);\r\n}\r\n\r\n.page-header {\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.page-header h1 {\r\n  margin: 0;\r\n  color: #303133;\r\n  font-size: 24px;\r\n  font-weight: 600;\r\n}\r\n\r\n.page-header p {\r\n  margin: 8px 0 0 0;\r\n  color: #909399;\r\n  font-size: 14px;\r\n}\r\n\r\n</style>\r\n\r\n<style scoped>\r\n.staff-dashboard {\r\n  padding: 20px;\r\n  background-color: #f5f7fa;\r\n  min-height: calc(100vh - 60px);\r\n}\r\n\r\n.page-header {\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.page-header h1 {\r\n  margin: 0;\r\n  color: #303133;\r\n  font-size: 24px;\r\n  font-weight: 600;\r\n}\r\n\r\n.page-header p {\r\n  margin: 8px 0 0 0;\r\n  color: #909399;\r\n  font-size: 14px;\r\n}\r\n\r\n/* 主要模块样式 */\r\n.main-modules {\r\n  margin-bottom: 30px;\r\n}\r\n\r\n.module-card {\r\n  border-radius: 12px;\r\n  border: none;\r\n  cursor: pointer;\r\n  transition: all 0.3s ease;\r\n  height: 220px;\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.module-card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1) !important;\r\n}\r\n\r\n.module-header {\r\n  display: flex;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.module-icon {\r\n  width: 50px;\r\n  height: 50px;\r\n  border-radius: 12px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  margin-right: 15px;\r\n  font-size: 24px;\r\n  color: white;\r\n}\r\n\r\n.attendance-module .module-icon {\r\n  background: linear-gradient(135deg, #409EFF, #66b1ff);\r\n}\r\n\r\n.leave-module .module-icon {\r\n  background: linear-gradient(135deg, #67C23A, #85ce61);\r\n}\r\n\r\n.salary-module .module-icon {\r\n  background: