{"remainingRequest":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\project\\java_project\\T021\\front\\src\\view\\staffs\\component\\SecuritySettings.vue?vue&type=script&lang=js","dependencies":[{"path":"E:\\project\\java_project\\T021\\front\\src\\view\\staffs\\component\\SecuritySettings.vue","mtime":1763004800038},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\babel-loader\\lib\\index.js","mtime":1762233498302},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1762233496489}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["SecuritySettings.vue"],"names":[],"mappings":";AAwCA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"SecuritySettings.vue","sourceRoot":"src/view/staffs/component","sourcesContent":["<template>\r\n  <div class=\"security-settings\">\r\n    <el-card header=\"修改密码\">\r\n      <el-form :model=\"passwordForm\" :rules=\"passwordRules\" ref=\"passwordFormRef\" label-width=\"100px\">\r\n        <el-form-item label=\"当前密码\" prop=\"currentPassword\">\r\n          <el-input\r\n              v-model=\"passwordForm.currentPassword\"\r\n              type=\"password\"\r\n              placeholder=\"请输入当前密码\"\r\n              show-password\r\n          />\r\n        </el-form-item>\r\n        <el-form-item label=\"新密码\" prop=\"newPassword\">\r\n          <el-input\r\n              v-model=\"passwordForm.newPassword\"\r\n              type=\"password\"\r\n              placeholder=\"请输入新密码\"\r\n              show-password\r\n          />\r\n        </el-form-item>\r\n        <el-form-item label=\"确认新密码\" prop=\"confirmPassword\">\r\n          <el-input\r\n              v-model=\"passwordForm.confirmPassword\"\r\n              type=\"password\"\r\n              placeholder=\"请再次输入新密码\"\r\n              show-password\r\n          />\r\n        </el-form-item>\r\n        <el-form-item>\r\n          <el-button type=\"primary\" @click=\"handleChangePassword\" :loading=\"loading\">\r\n            确认修改\r\n          </el-button>\r\n          <el-button @click=\"resetForm\">重置</el-button>\r\n        </el-form-item>\r\n      </el-form>\r\n    </el-card>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ref, getCurrentInstance } from 'vue'\r\nimport { ElMessage } from 'element-plus'\r\nimport API from '@/utils/api'\r\n\r\nexport default {\r\n  name: 'SecuritySettings',\r\n  setup() {\r\n    const { proxy } = getCurrentInstance()\r\n    const passwordFormRef = ref(null)\r\n    const loading = ref(false)\r\n    const passwordForm = ref({\r\n      currentPassword: '',\r\n      newPassword: '',\r\n      confirmPassword: ''\r\n    })\r\n\r\n    const validateConfirmPassword = (rule, value, callback) => {\r\n      if (value !== passwordForm.value.newPassword) {\r\n        callback(new Error('两次输入的密码不一致'))\r\n      } else {\r\n        callback()\r\n      }\r\n    }\r\n\r\n    const passwordRules = {\r\n      currentPassword: [\r\n        { required: true, message: '请输入当前密码', trigger: 'blur' }\r\n      ],\r\n      newPassword: [\r\n        { required: true, message: '请输入新密码', trigger: 'blur' },\r\n        { min: 6, message: '密码长度不能少于6位', trigger: 'blur' }\r\n      ],\r\n      confirmPassword: [\r\n        { required: true, message: '请确认新密码', trigger: 'blur' },\r\n        { validator: validateConfirmPassword, trigger: 'blur' }\r\n      ]\r\n    }\r\n\r\n    const handleChangePassword = async () => {\r\n      if (!passwordFormRef.value) return\r\n\r\n      try {\r\n        const valid = await passwordFormRef.value.validate()\r\n        if (valid) {\r\n          loading.value = true\r\n          // 使用 proxy 来访问 $http\r\n          const { data } = await proxy.$http.post(API.url.user.resetPass, {\r\n            oldPassword: passwordForm.value.currentPassword,\r\n            newPassword: passwordForm.value.newPassword\r\n          })\r\n\r\n          if (data && data.code === 0) {\r\n            ElMessage.success('密码修改成功')\r\n            resetForm()\r\n          } else {\r\n            ElMessage.error(data.msg || '密码修改失败')\r\n          }\r\n        }\r\n      } catch (error) {\r\n        console.error('修改密码失败:', error)\r\n        ElMessage.error('修改密码失败')\r\n      } finally {\r\n        loading.value = false\r\n      }\r\n    }\r\n\r\n    const resetForm = () => {\r\n      if (passwordFormRef.value) {\r\n        passwordFormRef.value.resetFields()\r\n      }\r\n    }\r\n\r\n    return {\r\n      passwordFormRef,\r\n      passwordForm,\r\n      passwordRules,\r\n      loading,\r\n      handleChangePassword,\r\n      resetForm\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.security-settings {\r\n  max-width: 600px;\r\n}\r\n</style>"]}]}