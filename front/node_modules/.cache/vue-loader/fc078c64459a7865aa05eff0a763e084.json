{"remainingRequest":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\project\\java_project\\T021\\front\\src\\view\\hr\\DepartmentManage.vue?vue&type=style&index=1&id=5414556a&scoped=true&lang=css","dependencies":[{"path":"E:\\project\\java_project\\T021\\front\\src\\view\\hr\\DepartmentManage.vue","mtime":1763095294074},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\css-loader\\dist\\cjs.js","mtime":1762233495618},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1762233498059},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\postcss-loader\\src\\index.js","mtime":1762233495756},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1762233496489}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["DepartmentManage.vue"],"names":[],"mappings":";AA+bA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA","file":"DepartmentManage.vue","sourceRoot":"src/view/hr","sourcesContent":["<template>\r\n  <div class=\"department-manage\">\r\n    <!-- 搜索和操作区域 -->\r\n    <div class=\"search-operate-area\">\r\n      <el-row :gutter=\"20\">\r\n        <el-col :span=\"6\">\r\n          <el-input\r\n              v-model=\"searchParams.dname\"\r\n              placeholder=\"请输入部门名称\"\r\n              clearable\r\n              @clear=\"handleSearch\"\r\n              @keyup.enter.native=\"handleSearch\"\r\n          >\r\n            <i slot=\"prefix\" class=\"el-input__icon el-icon-search\"></i>\r\n          </el-input>\r\n        </el-col>\r\n        <el-col :span=\"18\" style=\"text-align: right;\">\r\n          <el-button type=\"primary\" @click=\"handleSearch\">\r\n            <i class=\"el-icon-search\"></i>\r\n            搜索\r\n          </el-button>\r\n          <el-button @click=\"handleReset\">\r\n            <i class=\"el-icon-refresh\"></i>\r\n            重置\r\n          </el-button>\r\n          <el-button type=\"success\" @click=\"handleAdd\">\r\n            <i class=\"el-icon-plus\"></i>\r\n            新增部门\r\n          </el-button>\r\n        </el-col>\r\n      </el-row>\r\n    </div>\r\n\r\n    <!-- 数据表格 -->\r\n    <div class=\"table-area\">\r\n      <el-table\r\n          :data=\"tableData\"\r\n          v-loading=\"loading\"\r\n          border\r\n          style=\"width: 100%\"\r\n          :default-sort=\"{ prop: 'id', order: 'descending' }\"\r\n      >\r\n        <el-table-column type=\"index\" width=\"50\" label=\"序号\" />\r\n        <el-table-column prop=\"id\" label=\"部门ID\" width=\"80\" sortable />\r\n        <el-table-column prop=\"dname\" label=\"部门名称\" width=\"200\" />\r\n        <el-table-column prop=\"managerName\" label=\"部门负责人\" width=\"120\">\r\n          <template slot-scope=\"scope\">\r\n            <span v-if=\"scope.row.managerName\">{{ scope.row.managerName }}</span>\r\n            <span v-else style=\"color: #909399;\">未设置</span>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"staffCount\" label=\"员工数量\" width=\"100\" sortable>\r\n          <template slot-scope=\"scope\">\r\n            <el-tag type=\"info\">{{ scope.row.staffCount || 0 }}</el-tag>\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column prop=\"createTime\" label=\"创建时间\" width=\"160\" sortable>\r\n          <template slot-scope=\"scope\">\r\n            {{ formatDateTime(scope.row.createTime) }}\r\n          </template>\r\n        </el-table-column>\r\n        <el-table-column label=\"操作\" width=\"200\" fixed=\"right\">\r\n          <template slot-scope=\"scope\">\r\n            <el-button size=\"small\" @click=\"handleEdit(scope.row)\">编辑</el-button>\r\n            <el-button size=\"small\" type=\"warning\" @click=\"handleSetManager(scope.row)\">设置负责人</el-button>\r\n            <el-button size=\"small\" type=\"danger\" @click=\"handleDelete(scope.row)\" :disabled=\"scope.row.staffCount > 0\">删除</el-button>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n    </div>\r\n\r\n    <!-- 分页 -->\r\n    <div class=\"pagination-area\">\r\n      <el-pagination\r\n          :current-page=\"pagination.current\"\r\n          :page-size=\"pagination.size\"\r\n          :page-sizes=\"[10, 20, 50, 100]\"\r\n          :total=\"pagination.total\"\r\n          layout=\"total, sizes, prev, pager, next, jumper\"\r\n          @size-change=\"handleSizeChange\"\r\n          @current-change=\"handleCurrentChange\"\r\n      />\r\n    </div>\r\n\r\n    <!-- 新增/编辑部门对话框 -->\r\n    <el-dialog\r\n        :visible.sync=\"dialogVisible\"\r\n        :title=\"dialogType === 'add' ? '新增部门' : '编辑部门'\"\r\n        width=\"500px\"\r\n        @close=\"handleDialogClose\"\r\n    >\r\n      <el-form\r\n          ref=\"formRef\"\r\n          :model=\"formData\"\r\n          :rules=\"formRules\"\r\n          label-width=\"100px\"\r\n      >\r\n        <el-form-item label=\"部门名称\" prop=\"dname\">\r\n          <el-input v-model=\"formData.dname\" placeholder=\"请输入部门名称\" />\r\n        </el-form-item>\r\n\r\n        <el-form-item label=\"部门负责人\" prop=\"managerId\">\r\n          <el-select\r\n              v-model=\"formData.managerId\"\r\n              placeholder=\"请选择部门负责人\"\r\n              style=\"width: 100%\"\r\n              clearable\r\n              filterable\r\n          >\r\n            <el-option\r\n                v-for=\"staff in staffOptions\"\r\n                :key=\"staff.id\"\r\n                :label=\"`${staff.sname} (${staff.sid})`\"\r\n                :value=\"staff.id\"\r\n            />\r\n          </el-select>\r\n        </el-form-item>\r\n      </el-form>\r\n\r\n      <span slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"handleSubmit\" :loading=\"submitting\">确定</el-button>\r\n      </span>\r\n    </el-dialog>\r\n\r\n    <!-- 设置负责人对话框 -->\r\n    <el-dialog :visible.sync=\"managerDialogVisible\" title=\"设置部门负责人\" width=\"500px\">\r\n      <el-form>\r\n        <el-form-item label=\"部门名称\">\r\n          <el-input :value=\"currentDepartment.dname\" disabled />\r\n        </el-form-item>\r\n\r\n        <el-form-item label=\"选择负责人\">\r\n          <el-select v-model=\"selectedManagerId\" placeholder=\"请选择部门负责人\" style=\"width:100%\" filterable>\r\n            <el-option\r\n                v-for=\"staff in availableManagers\"\r\n                :key=\"staff.id\"\r\n                :label=\"`${staff.sname} (${staff.sid}) - ${staff.jobName || staff.job_name || ''}`\"\r\n                :value=\"staff.id\"\r\n            />\r\n          </el-select>\r\n        </el-form-item>\r\n      </el-form>\r\n\r\n      <span slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"managerDialogVisible = false\">取消</el-button>\r\n        <el-button type=\"primary\" @click=\"handleSetManagerSubmit\" :loading=\"submitting\">确定</el-button>\r\n      </span>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport API from '@/utils/api'\r\n\r\nexport default {\r\n  name: 'DepartmentManage',\r\n  data() {\r\n    return {\r\n      loading: false,\r\n      dialogVisible: false,\r\n      managerDialogVisible: false,\r\n      dialogType: 'add',\r\n      submitting: false,\r\n\r\n      tableData: [],\r\n\r\n      // 使用后端返回的字段名：dname, managerId\r\n      searchParams: {\r\n        dname: ''\r\n      },\r\n\r\n      pagination: {\r\n        current: 1,\r\n        size: 10,\r\n        total: 0\r\n      },\r\n\r\n      formData: {\r\n        id: '',\r\n        dname: '',\r\n        managerId: null\r\n      },\r\n\r\n      currentDepartment: {},\r\n      selectedManagerId: null,\r\n      staffOptions: [],\r\n      availableManagers: [],\r\n\r\n      formRules: {\r\n        dname: [\r\n          { required: true, message: '请输入部门名称', trigger: 'blur' },\r\n          { min: 2, max: 50, message: '部门名称长度为2-50个字符', trigger: 'blur' }\r\n        ]\r\n      }\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadTableData()\r\n    this.loadStaffOptions()\r\n  },\r\n  methods: {\r\n    // 加载表格数据，兼容 page/list 两种返回结构\r\n    async loadTableData() {\r\n      this.loading = true\r\n      try {\r\n        const params = {\r\n          page: this.pagination.current,\r\n          size: this.pagination.size,\r\n          ...this.searchParams\r\n        }\r\n        // 删除空字段\r\n        Object.keys(params).forEach(k => {\r\n          if (params[k] === '' || params[k] === null || params[k] === undefined) delete params[k]\r\n        })\r\n\r\n        console.log('请求部门参数:', params)\r\n\r\n        // 使用统一的 this.$http（axios 实例），发送到 page 接口（后端分页）\r\n        const response = await this.$http.get(API.url.department.page, { params })\r\n\r\n        if (!(response && response.data)) {\r\n          throw new Error('无效响应')\r\n        }\r\n\r\n        if (response.data.code !== 0) {\r\n          this.$message.error(response.data.msg || '加载部门失败')\r\n          return\r\n        }\r\n\r\n        // 兼容：data.list / data.page.records / data.records\r\n        const payload = response.data.data || response.data.page || {}\r\n        let list = []\r\n        let total = 0\r\n\r\n        if (Array.isArray(response.data.data)) {\r\n          list = response.data.data\r\n          total = list.length\r\n        } else if (payload.list && Array.isArray(payload.list)) {\r\n          list = payload.list\r\n          total = payload.total || payload.totalCount || payload.count || response.data.data.total || response.data.data.total\r\n        } else if (payload.records && Array.isArray(payload.records)) {\r\n          list = payload.records\r\n          total = payload.total || payload.totalCount || payload.count || 0\r\n        } else if (payload.data && Array.isArray(payload.data)) {\r\n          list = payload.data\r\n          total = list.length\r\n        }\r\n\r\n        // 标准化字段：后端用 dname/managerName/staffCount/createTime\r\n        this.tableData = list.map(item => ({\r\n          id: item.id,\r\n          dname: item.dname || item.Dname || item.departmentName || item.name,\r\n          managerId: item.managerId || item.manager_id,\r\n          managerName: item.managerName || item.manager_name || (item.manager ? item.manager.sname : null),\r\n          staffCount: item.staffCount != null ? item.staffCount : (item.staff_count != null ? item.staff_count : 0),\r\n          createTime: item.createTime || item.create_time || item.createTimeMillis || item.create_time_ms || item.create\r\n        }))\r\n\r\n        this.pagination.total = total || this.tableData.length\r\n      } catch (err) {\r\n        console.error('加载部门数据失败:', err)\r\n        this.$message.error('加载部门数据失败: ' + (err.message || '未知错误'))\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    async loadStaffOptions() {\r\n      try {\r\n        const response = await this.$http.get(API.url.user.list)\r\n        if (response && response.data && response.data.code === 0) {\r\n          // 兼容后端字段 sname/sid\r\n          const raw = response.data.data || response.data.list || []\r\n          this.staffOptions = raw.map(u => ({ id: u.id, sname: u.sname || u.Sname, sid: u.sid || u.Sid, jobName: u.jobName || u.job_name }))\r\n        }\r\n      } catch (err) {\r\n        console.error('加载员工选项失败:', err)\r\n      }\r\n    },\r\n\r\n    handleSearch() {\r\n      this.pagination.current = 1\r\n      this.loadTableData()\r\n    },\r\n\r\n    handleReset() {\r\n      this.searchParams = { dname: '' }\r\n      this.pagination.current = 1\r\n      this.loadTableData()\r\n    },\r\n\r\n    handleAdd() {\r\n      this.dialogType = 'add'\r\n      this.dialogVisible = true\r\n      this.resetForm()\r\n    },\r\n\r\n    handleEdit(row) {\r\n      this.dialogType = 'edit'\r\n      this.dialogVisible = true\r\n      this.formData = {\r\n        id: row.id,\r\n        dname: row.dname,\r\n        managerId: row.managerId || null\r\n      }\r\n    },\r\n\r\n    async handleSetManager(row) {\r\n      this.currentDepartment = { ...row }\r\n      this.selectedManagerId = row.managerId || null\r\n      try {\r\n        // 请求部门下员工（若后端支持按 dept 参数过滤）\r\n        const res = await this.$http.get(API.url.user.list, { params: { deptId: row.id } })\r\n        if (res && res.data && res.data.code === 0) {\r\n          const raw = res.data.data || res.data.list || []\r\n          this.availableManagers = raw.map(u => ({ id: u.id, sname: u.sname || u.Sname, sid: u.sid || u.Sid, jobName: u.jobName || u.job_name }))\r\n        } else {\r\n          this.availableManagers = []\r\n        }\r\n        this.managerDialogVisible = true\r\n      } catch (err) {\r\n        console.error('加载部门员工失败:', err)\r\n        this.$message.error('加载部门员工失败')\r\n      }\r\n    },\r\n\r\n    async handleSetManagerSubmit() {\r\n      if (!this.selectedManagerId) {\r\n        this.$message.warning('请选择部门负责人')\r\n        return\r\n      }\r\n      this.submitting = true\r\n      try {\r\n        const payload = { id: this.currentDepartment.id, managerId: this.selectedManagerId }\r\n        const res = await this.$http.post(API.url.department.update, payload)\r\n        if (res && res.data && res.data.code === 0) {\r\n          this.$message.success('设置负责人成功')\r\n          this.managerDialogVisible = false\r\n          this.loadTableData()\r\n        } else {\r\n          this.$message.error(res.data?.msg || '设置负责人失败')\r\n        }\r\n      } catch (err) {\r\n        console.error('设置负责人失败:', err)\r\n        this.$message.error('设置负责人失败')\r\n      } finally {\r\n        this.submitting = false\r\n      }\r\n    },\r\n\r\n    async handleDelete(row) {\r\n      try {\r\n        await this.$confirm(`确定要删除部门 \"${row.dname}\" 吗？此操作不可恢复！`, '删除确认', { confirmButtonText: '确定', cancelButtonText: '取消', type: 'error' })\r\n        if (row.staffCount > 0) {\r\n          this.$message.error('该部门下还有员工，无法删除')\r\n          return\r\n        }\r\n        const res = await this.$http.post(API.url.department.delete, { id: row.id })\r\n        if (res && res.data && res.data.code === 0) {\r\n          this.$message.success('删除成功')\r\n          this.loadTableData()\r\n        } else {\r\n          this.$message.error(res.data?.msg || '删除失败')\r\n        }\r\n      } catch (err) {\r\n        if (err !== 'cancel') {\r\n          console.error('删除失败:', err)\r\n          this.$message.error('删除失败')\r\n        }\r\n      }\r\n    },\r\n\r\n    async handleSubmit() {\r\n      try {\r\n        await this.$refs.formRef.validate()\r\n        this.submitting = true\r\n        const payload = { ...this.formData }\r\n        const url = this.dialogType === 'add' ? API.url.department.save : API.url.department.update\r\n        const res = await this.$http.post(url, payload)\r\n        if (res && res.data && res.data.code === 0) {\r\n          this.$message.success(this.dialogType === 'add' ? '新增成功' : '编辑成功')\r\n          this.dialogVisible = false\r\n          this.loadTableData()\r\n        } else {\r\n          this.$message.error(res.data?.msg || '操作失败')\r\n        }\r\n      } catch (err) {\r\n        console.error('表单提交失败:', err)\r\n        this.$message.error('表单提交失败')\r\n      } finally {\r\n        this.submitting = false\r\n      }\r\n    },\r\n\r\n    resetForm() {\r\n      if (this.$refs.formRef) this.$refs.formRef.resetFields()\r\n      this.formData = { id: '', dname: '', managerId: null }\r\n    },\r\n\r\n    handleDialogClose() {\r\n      this.resetForm()\r\n    },\r\n\r\n    handleSizeChange(size) {\r\n      this.pagination.size = size\r\n      this.pagination.current = 1\r\n      this.loadTableData()\r\n    },\r\n\r\n    handleCurrentChange(current) {\r\n      this.pagination.current = current\r\n      this.loadTableData()\r\n    },\r\n\r\n    formatDateTime(ts) {\r\n      if (!ts && ts !== 0) return ''\r\n      try {\r\n        const n = typeof ts === 'number' ? ts : Number(ts)\r\n        const date = new Date(n)\r\n        if (isNaN(date.getTime())) return ts\r\n        const y = date.getFullYear()\r\n        const m = String(date.getMonth() + 1).padStart(2, '0')\r\n        const d = String(date.getDate()).padStart(2, '0')\r\n        const hh = String(date.getHours()).padStart(2, '0')\r\n        const mm = String(date.getMinutes()).padStart(2, '0')\r\n        const ss = String(date.getSeconds()).padStart(2, '0')\r\n        return `${y}-${m}-${d} ${hh}:${mm}:${ss}`\r\n      } catch (err) {\r\n        return ts\r\n      }\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.department-manage { padding: 20px; background: #fff; border-radius: 4px }\r\n.search-operate-area { margin-bottom: 20px }\r\n.table-area { margin-bottom: 20px }\r\n.pagination-area { display:flex; justify-content:flex-end }\r\n::v-deep .el-table .cell { text-align: center }\r\n::v-deep .el-table th > .cell { text-align: center }\r\n</style>\r\n\r\n\r\n<style scoped>\r\n.department-manage {\r\n  padding: 20px;\r\n  background: #fff;\r\n  border-radius: 4px;\r\n}\r\n\r\n.search-operate-area {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.table-area {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.pagination-area {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n}\r\n</style>"]}]}