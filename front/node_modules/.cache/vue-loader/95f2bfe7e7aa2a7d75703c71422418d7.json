{"remainingRequest":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\project\\java_project\\T021\\front\\src\\view\\staffs\\component\\AvatarUpload.vue?vue&type=style&index=0&id=901b2552&scoped=true&lang=scss","dependencies":[{"path":"E:\\project\\java_project\\T021\\front\\src\\view\\staffs\\component\\AvatarUpload.vue","mtime":1763020217431},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\css-loader\\dist\\cjs.js","mtime":1762233495618},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1762233498059},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\postcss-loader\\src\\index.js","mtime":1762233495756},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1762234960396},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1762233496489}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["AvatarUpload.vue"],"names":[],"mappings":";AAgOA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA","file":"AvatarUpload.vue","sourceRoot":"src/view/staffs/component","sourcesContent":["<script setup lang=\"ts\">\r\nimport { ref, reactive } from 'vue'\r\nimport { ElMessage } from 'element-plus'\r\nimport type { UploadProps, UploadUserFile } from 'element-plus'\r\n\r\n// 用户信息\r\nconst userInfo = reactive({\r\n  name: '张明',\r\n  departmentName: '技术部',\r\n  jobTitle: '后端开发工程师',\r\n  status: 'active',\r\n  avatar: ''\r\n})\r\n\r\n// 默认头像\r\nconst defaultAvatar = ref('')\r\n\r\n// 控制头像弹窗显示\r\nconst showAvatarDialog = ref(false)\r\n\r\n// 上传相关状态\r\nconst avatarFileList = ref<UploadUserFile[]>([])\r\nconst cropperDialogVisible = ref(false)\r\nconst currentAvatarFile = ref<File | null>(null)\r\n\r\n// 头像上传前的处理\r\nconst beforeAvatarUpload: UploadProps['beforeUpload'] = (rawFile) => {\r\n  // 检查文件类型\r\n  const isJPGOrPNG = rawFile.type === 'image/jpeg' || rawFile.type === 'image/png'\r\n  if (!isJPGOrPNG) {\r\n    ElMessage.error('头像必须是 JPG 或 PNG 格式!')\r\n    return false\r\n  }\r\n\r\n  // 检查文件大小 (2MB)\r\n  const isLt2M = rawFile.size / 1024 / 1024 < 2\r\n  if (!isLt2M) {\r\n    ElMessage.error('头像图片大小不能超过 2MB!')\r\n    return false\r\n  }\r\n\r\n  // 保存文件并显示裁剪对话框\r\n  currentAvatarFile.value = rawFile\r\n  cropperDialogVisible.value = true\r\n\r\n  return false // 阻止自动上传\r\n}\r\n\r\n// 处理头像上传成功\r\nconst handleAvatarSuccess: UploadProps['onSuccess'] = (response) => {\r\n  // 这里应该是上传到服务器后的响应，包含头像URL\r\n  if (response && response.data && response.data.avatarUrl) {\r\n    userInfo.avatar = response.data.avatarUrl\r\n    ElMessage.success('头像上传成功!')\r\n  } else {\r\n    // 模拟上传成功，实际项目中应该使用服务器返回的URL\r\n    const reader = new FileReader()\r\n    reader.onload = (e) => {\r\n      userInfo.avatar = e.target?.result as string\r\n      ElMessage.success('头像上传成功!')\r\n    }\r\n    if (currentAvatarFile.value) {\r\n      reader.readAsDataURL(currentAvatarFile.value)\r\n    }\r\n  }\r\n\r\n  showAvatarDialog.value = false\r\n  cropperDialogVisible.value = false\r\n  avatarFileList.value = []\r\n}\r\n\r\n// 处理头像上传错误\r\nconst handleAvatarError = () => {\r\n  ElMessage.error('头像上传失败，请重试!')\r\n}\r\n\r\n// 关闭头像弹窗\r\nconst handleAvatarDialogClose = () => {\r\n  showAvatarDialog.value = false\r\n  avatarFileList.value = []\r\n}\r\n\r\n// 确认使用裁剪后的头像\r\nconst confirmCroppedAvatar = (croppedAvatarUrl: string) => {\r\n  userInfo.avatar = croppedAvatarUrl\r\n  ElMessage.success('头像更新成功!')\r\n  cropperDialogVisible.value = false\r\n  showAvatarDialog.value = false\r\n\r\n  // 这里应该调用API将头像上传到服务器\r\n  // uploadAvatarToServer(croppedAvatarUrl)\r\n}\r\n</script>\r\n\r\n<template>\r\n  <div class=\"center-content\">\r\n    <!-- 左侧个人信息卡片 -->\r\n    <div class=\"left-sidebar\">\r\n      <el-card class=\"user-card\">\r\n        <div class=\"user-avatar-section\">\r\n          <el-avatar\r\n              :size=\"80\"\r\n              :src=\"userInfo.avatar || defaultAvatar\"\r\n              @click=\"showAvatarDialog = true\"\r\n              class=\"user-avatar\"\r\n          >\r\n            {{ userInfo.name ? userInfo.name.charAt(0) : 'U' }}\r\n          </el-avatar>\r\n          <div class=\"user-basic-info\">\r\n            <h3>{{ userInfo.name || '未知用户' }}</h3>\r\n            <p class=\"user-department\">{{ userInfo.departmentName || '未分配部门' }}</p>\r\n            <p class=\"user-job\">{{ userInfo.jobTitle || '未分配岗位' }}</p>\r\n            <el-tag\r\n                :type=\"userInfo.status === 'active' ? 'success' : 'danger'\"\r\n                size=\"small\"\r\n            >\r\n              {{ userInfo.status === 'active' ? '在职' : '离职' }}\r\n            </el-tag>\r\n          </div>\r\n        </div>\r\n\r\n        <!-- 上传头像按钮 -->\r\n        <div class=\"avatar-upload-tip\">\r\n          <el-button\r\n              type=\"primary\"\r\n              link\r\n              @click=\"showAvatarDialog = true\"\r\n          >\r\n            点击更换头像\r\n          </el-button>\r\n        </div>\r\n      </el-card>\r\n    </div>\r\n\r\n    <!-- 头像上传对话框 -->\r\n    <el-dialog\r\n        v-model=\"showAvatarDialog\"\r\n        title=\"更换头像\"\r\n        width=\"500px\"\r\n        :before-close=\"handleAvatarDialogClose\"\r\n    >\r\n      <div class=\"avatar-upload-dialog\">\r\n        <!-- 当前头像预览 -->\r\n        <div class=\"current-avatar-section\">\r\n          <h4>当前头像</h4>\r\n          <el-avatar\r\n              :size=\"100\"\r\n              :src=\"userInfo.avatar || defaultAvatar\"\r\n              class=\"current-avatar\"\r\n          >\r\n            {{ userInfo.name ? userInfo.name.charAt(0) : 'U' }}\r\n          </el-avatar>\r\n        </div>\r\n\r\n        <!-- 头像上传区域 -->\r\n        <div class=\"upload-section\">\r\n          <h4>上传新头像</h4>\r\n          <el-upload\r\n              v-model:file-list=\"avatarFileList\"\r\n              class=\"avatar-uploader\"\r\n              action=\"/api/upload/avatar\"  // 替换为实际的上传接口\r\n          :show-file-list=\"false\"\r\n          :before-upload=\"beforeAvatarUpload\"\r\n          :on-success=\"handleAvatarSuccess\"\r\n          :on-error=\"handleAvatarError\"\r\n          accept=\".jpg,.jpeg,.png\"\r\n          >\r\n          <div class=\"upload-area\">\r\n            <el-icon class=\"el-icon--upload\"><plus /></el-icon>\r\n            <div class=\"el-upload__text\">\r\n              点击上传或拖拽图片到此区域\r\n            </div>\r\n            <div class=\"el-upload__tip\">\r\n              支持 JPG、PNG 格式，大小不超过 2MB\r\n            </div>\r\n          </div>\r\n          </el-upload>\r\n        </div>\r\n      </div>\r\n\r\n      <template #footer>\r\n        <span class=\"dialog-footer\">\r\n          <el-button @click=\"handleAvatarDialogClose\">取消</el-button>\r\n        </span>\r\n      </template>\r\n    </el-dialog>\r\n\r\n    <!-- 头像裁剪对话框 -->\r\n    <el-dialog\r\n        v-model=\"cropperDialogVisible\"\r\n        title=\"裁剪头像\"\r\n        width=\"600px\"\r\n    >\r\n      <div class=\"avatar-cropper-dialog\">\r\n        <!-- 这里可以集成图片裁剪组件，如 vue-cropper -->\r\n        <div class=\"cropper-container\">\r\n          <p>图片裁剪区域 (实际项目中可集成 vue-cropper 等裁剪库)</p>\r\n          <div class=\"cropper-preview\">\r\n            <img\r\n                v-if=\"currentAvatarFile\"\r\n                :src=\"URL.createObjectURL(currentAvatarFile)\"\r\n                alt=\"预览\"\r\n                style=\"max-width: 100%; max-height: 300px;\"\r\n            />\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <template #footer>\r\n        <span class=\"dialog-footer\">\r\n          <el-button @click=\"cropperDialogVisible = false\">取消</el-button>\r\n          <el-button\r\n              type=\"primary\"\r\n              @click=\"confirmCroppedAvatar(URL.createObjectURL(currentAvatarFile!))\"\r\n          >\r\n            确认\r\n          </el-button>\r\n        </span>\r\n      </template>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<style scoped lang=\"scss\">\r\n.center-content {\r\n  display: flex;\r\n  gap: 20px;\r\n}\r\n\r\n.left-sidebar {\r\n  width: 300px;\r\n}\r\n\r\n.user-card {\r\n  text-align: center;\r\n\r\n  .user-avatar-section {\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    margin-bottom: 16px;\r\n\r\n    .user-avatar {\r\n      cursor: pointer;\r\n      margin-bottom: 12px;\r\n      border: 2px solid #f0f0f0;\r\n      transition: border-color 0.3s;\r\n\r\n      &:hover {\r\n        border-color: #409eff;\r\n      }\r\n    }\r\n\r\n    .user-basic-info {\r\n      h3 {\r\n        margin: 0 0 8px 0;\r\n        font-size: 18px;\r\n        color: #303133;\r\n      }\r\n\r\n      .user-department,\r\n      .user-job {\r\n        margin: 4px 0;\r\n        color: #606266;\r\n        font-size: 14px;\r\n      }\r\n    }\r\n  }\r\n\r\n  .avatar-upload-tip {\r\n    margin-top: 12px;\r\n\r\n    .el-button {\r\n      font-size: 12px;\r\n    }\r\n  }\r\n}\r\n\r\n.avatar-upload-dialog {\r\n  .current-avatar-section {\r\n    text-align: center;\r\n    margin-bottom: 24px;\r\n\r\n    h4 {\r\n      margin-bottom: 12px;\r\n      color: #303133;\r\n    }\r\n\r\n    .current-avatar {\r\n      border: 2px solid #e0e0e0;\r\n    }\r\n  }\r\n\r\n  .upload-section {\r\n    h4 {\r\n      margin-bottom: 12px;\r\n      color: #303133;\r\n    }\r\n\r\n    .avatar-uploader {\r\n      .upload-area {\r\n        border: 2px dashed #d9d9d9;\r\n        border-radius: 6px;\r\n        padding: 40px 20px;\r\n        text-align: center;\r\n        cursor: pointer;\r\n        transition: border-color 0.3s;\r\n\r\n        &:hover {\r\n          border-color: #409eff;\r\n        }\r\n\r\n        .el-icon--upload {\r\n          font-size: 48px;\r\n          color: #c0c4cc;\r\n          margin-bottom: 16px;\r\n        }\r\n\r\n        .el-upload__text {\r\n          color: #606266;\r\n          font-size: 14px;\r\n          margin-bottom: 8px;\r\n        }\r\n\r\n        .el-upload__tip {\r\n          color: #909399;\r\n          font-size: 12px;\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n.avatar-cropper-dialog {\r\n  .cropper-container {\r\n    text-align: center;\r\n\r\n    p {\r\n      margin-bottom: 16px;\r\n      color: #606266;\r\n    }\r\n\r\n    .cropper-preview {\r\n      border: 1px solid #e0e0e0;\r\n      border-radius: 4px;\r\n      padding: 16px;\r\n      background: #fafafa;\r\n    }\r\n  }\r\n}\r\n\r\n.dialog-footer {\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: 12px;\r\n}\r\n</style>"]}]}