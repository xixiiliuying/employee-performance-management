r\n            <el-input v-model=\"ruleForm.sid\" readonly placeholder=\"员工号\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n\r\n        <!-- 员工姓名 -->\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"员工姓名\" prop=\"sname\">\r\n            <el-input v-model=\"ruleForm.sname\" placeholder=\"员工姓名\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n\r\n        <!-- 性别 -->\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"性别\" prop=\"gender\">\r\n            <el-select v-model=\"ruleForm.gender\" placeholder=\"请选择性别\">\r\n              <el-option\r\n                  v-for=\"(item,index) in genderOptions\"\r\n                  v-bind:key=\"index\"\r\n                  :label=\"item\"\r\n                  :value=\"item\">\r\n              </el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n        </el-col>\r\n\r\n        <!-- 角色 -->\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"角色\" prop=\"role\">\r\n            <el-input v-model=\"roleText\" readonly placeholder=\"角色\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n\r\n        <!-- 部门 -->\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"部门\" prop=\"deptId\">\r\n            <el-select v-model=\"ruleForm.deptId\" placeholder=\"请选择部门\" clearable>\r\n              <el-option\r\n                  v-for=\"item in departmentOptions\"\r\n                  v-bind:key=\"item.id\"\r\n                  :label=\"item.dname\"\r\n                  :value=\"item.id\">\r\n              </el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n        </el-col>\r\n\r\n        <!-- 岗位 -->\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"岗位\" prop=\"jobId\">\r\n            <el-select v-model=\"ruleForm.jobId\" placeholder=\"请选择岗位\" clearable>\r\n              <el-option\r\n                  v-for=\"item in jobOptions\"\r\n                  v-bind:key=\"item.id\"\r\n                  :label=\"item.jname\"\r\n                  :value=\"item.id\">\r\n              </el-option>\r\n            </el-select>\r\n          </el-form-item>\r\n        </el-col>\r\n\r\n        <!-- 联系电话 -->\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"联系电话\" prop=\"phone\">\r\n            <el-input v-model=\"ruleForm.phone\" placeholder=\"联系电话\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n\r\n        <!-- 邮箱 -->\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"邮箱\" prop=\"email\">\r\n            <el-input v-model=\"ruleForm.email\" placeholder=\"邮箱\"></el-input>\r\n          </el-form-item>\r\n        </el-col>\r\n\r\n        <!-- 入职日期 -->\r\n        <el-col :span=\"12\">\r\n          <el-form-item label=\"入职日期\" prop=\"hireDate\">\r\n            <el-date-picker\r\n                v-model=\"ruleForm.hireDate\"\r\n                type=\"date\"\r\n                placeholder=\"选择入职日期\"\r\n                value-format=\"yyyy-MM-dd\"\r\n                format=\"yyyy-MM-dd\"\r\n                readonly>\r\n            </el-date-picker>\r\n          </el-form-item>\r\n        </el-col>\r\n\r\n        <!-- 修改按钮 -->\r\n        <el-col :span=\"24\">\r\n          <el-form-item>\r\n            <el-button type=\"primary\" @click=\"onUpdateHandler\" :loading=\"loading\">修 改</el-button>\r\n          </el-form-item>\r\n        </el-col>\r\n      </el-row>\r\n    </el-form>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { isEmail, isMobile } from \"@/utils/validate\";\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      ruleForm: {},\r\n      flag: '',\r\n      loading: false,\r\n      genderOptions: ['男', '女'],\r\n      departmentOptions: [],\r\n      jobOptions: []\r\n    };\r\n  },\r\n  computed: {\r\n    roleText() {\r\n      if (!this.ruleForm.role) return ''\r\n      return this.ruleForm.role === 'hr' ? 'HR管理员' : '员工'\r\n    }\r\n  },\r\n  mounted() {\r\n    this.init();\r\n  },\r\n  methods: {\r\n    init() {\r\n      // 设置表标识\r\n      this.flag = this.$storage.get(\"sessionTable\") || 'users';\r\n\r\n      // 获取用户信息\r\n      this.getUserInfo();\r\n\r\n      // 加载部门选项\r\n      this.loadDepartmentOptions();\r\n\r\n      // 加载岗位选项\r\n      this.loadJobOptions();\r\n    },\r\n\r\n    // 获取用户信息\r\n    getUserInfo() {\r\n      this.$http({\r\n        url: this.$api.url.user.session,\r\n        method: \"get\"\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.ruleForm = data.data;\r\n          console.log('用户信息:', this.ruleForm);\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('获取用户信息失败:', error);\r\n        this.$message.error('获取用户信息失败');\r\n      });\r\n    },\r\n\r\n    // 加载部门选项\r\n    loadDepartmentOptions() {\r\n      this.$http({\r\n        url: this.$api.url.department.list,\r\n        method: \"get\",\r\n        params: {\r\n          page: 1,\r\n          limit: 100\r\n        }\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.departmentOptions = data.data.records || data.data;\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('获取部门选项失败:', error);\r\n        this.$message.error('获取部门选项失败');\r\n      });\r\n    },\r\n\r\n    // 加载岗位选项\r\n    loadJobOptions() {\r\n      this.$http({\r\n        url: this.$api.url.job.list,\r\n        method: \"get\",\r\n        params: {\r\n          page: 1,\r\n          limit: 100\r\n        }\r\n      }).then(({ data }) => {\r\n        if (data && data.code === 0) {\r\n          this.jobOptions = data.data.records || data.data;\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        console.error('获取岗位选项失败:', error);\r\n        this.$message.error('获取岗位选项失败');\r\n      });\r\n    },\r\n\r\n    onUpdateHandler() {\r\n      // 表单验证\r\n      if (!this.ruleForm.sid) {\r\n        this.$message.error('员工号不能为空');\r\n        return;\r\n      }\r\n\r\n      if (!this.ruleForm.sname) {\r\n        this.$message.error('员工姓名不能为空');\r\n        return;\r\n      }\r\n\r\n      if (!this.ruleForm.gender) {\r\n        this.$message.error('请选择性别');\r\n        return;\r\n      }\r\n\r\n      if (this.ruleForm.phone && (!isMobile(this.ruleForm.phone))) {\r\n        this.$message.error('联系电话应输入手机格式');\r\n        return;\r\n      }\r\n\r\n      if (this.ruleForm.email && (!isEmail(this.ruleForm.email))) {\r\n        this.$message.error('邮箱应输入邮箱格式');\r\n        return;\r\n      }\r\n\r\n      this.loading = true;\r\n\r\n      // 更新用户信息\r\n      this.$http({\r\n        url: this.$api.url.user.update,\r\n        method: \"post\",\r\n        data: this.ruleForm\r\n      }).then(({ data }) => {\r\n        this.loading = false;\r\n        if (data && data.code === 0) {\r\n          this.$message({\r\n            message: \"修改信息成功\",\r\n            type: \"success\",\r\n            duration: 1500,\r\n            onClose: () => {\r\n              // 可以在这里添加成功后的操作\r\n              console.log('用户信息更新成功');\r\n            }\r\n          });\r\n        } else {\r\n          this.$message.error(data.msg);\r\n        }\r\n      }).catch(error => {\r\n        this.loading = false;\r\n        console.error('更新用户信息失败:', error);\r\n        this.$message.error('更新失败，请稍后重试');\r\n      });\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.detail-form-content {\r\n  max-width: 800px;\r\n  margin: 0 auto;\r\n  padding: 30px 20px;\r\n  background: #fff;\r\n  border-radius: 8px;\r\n  box-shadow: 0 2px 12px 0 rgba(0, 0, 0, 0.1);\r\n\r\n  .el-row {\r\n    margin-bottom: 10px;\r\n  }\r\n\r\n  .el-col {\r\n    padding: 0 10px;\r\n  }\r\n\r\n  .el-form-item {\r\n    margin-bottom: 22px;\r\n\r\n    .el-input, .el-select, .el-date-picker {\r\n      width: 100%;\r\n    }\r\n\r\n    :deep(.el-input__inner) {\r\n      height: 40px;\r\n      line-height: 40px;\r\n    }\r\n  }\r\n\r\n  .el-button {\r\n    width: 200px;\r\n    height: 40px;\r\n    font-size: 16px;\r\n  }\r\n}\r\n\r\n// 响应式设计\r\n@media (max-width: 768px) {\r\n  .detail-form-content {\r\n    padding: 20px 15px;\r\n    margin: 10px;\r\n\r\n    .el-col {\r\n      padding: 0 5px;\r\n    }\r\n\r\n    .el-form-item {\r\n      margin-bottom: 18px;\r\n    }\r\n\r\n    .el-button {\r\n      width: 100%;\r\n    }\r\n  }\r\n}\r\n</style>"]}]}