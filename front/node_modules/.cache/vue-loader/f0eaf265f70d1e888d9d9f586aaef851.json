        header-align=\"center\"\n                                  label=\"部门\">\n                  <template slot-scope=\"scope\">\n                       {{scope.row.bumen}}\n                     </template>\n                </el-table-column>\n                <el-table-column  :sortable=\"contents.tableSortable\" :align=\"contents.tableAlign\"\n                    prop=\"gangwei\"\n                    header-align=\"center\"\n                                  label=\"岗位\">\n                  <template slot-scope=\"scope\">\n                       {{scope.row.gangwei}}\n                     </template>\n                </el-table-column>\n                <el-table-column  :sortable=\"contents.tableSortable\" :align=\"contents.tableAlign\"\n                    prop=\"jixiaoxiangmu\"\n                    header-align=\"center\"\n                                  label=\"绩效项目\">\n                  <template slot-scope=\"scope\">\n                       {{scope.row.jixiaoxiangmu}}\n                     </template>\n                </el-table-column>\n                <el-table-column  :sortable=\"contents.tableSortable\" :align=\"contents.tableAlign\"\n                    prop=\"jixiaozhibiao1\"\n                    header-align=\"center\"\n                                  label=\"绩效指标1\">\n                  <template slot-scope=\"scope\">\n                       {{scope.row.jixiaozhibiao1}}\n                     </template>\n                </el-table-column>\n                <el-table-column  :sortable=\"contents.tableSortable\" :align=\"contents.tableAlign\"\n                    prop=\"fenzhi1\"\n                    header-align=\"center\"\n                                  label=\"分值1\">\n                  <template slot-scope=\"scope\">\n                       {{scope.row.fenzhi1}}\n                     </template>\n                </el-table-column>\n                <el-table-column  :sortable=\"contents.tableSortable\" :align=\"contents.tableAlign\"\n                    prop=\"jixiaozhibiao2\"\n                    header-align=\"center\"\n                                  label=\"绩效指标2\">\n                  <template slot-scope=\"scope\">\n                       {{scope.row.jixiaozhibiao2}}\n                     </template>\n                </el-table-column>\n                <el-table-column  :sortable=\"contents.tableSortable\" :align=\"contents.tableAlign\"\n                    prop=\"fenzhi2\"\n                    header-align=\"center\" label=\"分值2\">\n                  <template slot-scope=\"scope\">\n                       {{scope.row.fenzhi2}}\n                     </template>\n                </el-table-column>\n                <el-table-column  :sortable=\"contents.tableSortable\" :align=\"contents.tableAlign\"\n                    prop=\"jixiaozhibiao3\"\n                    header-align=\"center\" label=\"绩效指标3\">\n                  <template slot-scope=\"scope\">\n                       {{scope.row.jixiaozhibiao3}}\n                     </template>\n                </el-table-column>\n                <el-table-column  :sortable=\"contents.tableSortable\" :align=\"contents.tableAlign\"\n                    prop=\"fenzhi3\"\n                    header-align=\"center\" label=\"分值3\">\n                  <template slot-scope=\"scope\">\n                       {{scope.row.fenzhi3}}\n                     </template>\n                </el-table-column>\n                <el-table-column  :sortable=\"contents.tableSortable\" :align=\"contents.tableAlign\"\n                    prop=\"zongpingfen\"\n                    header-align=\"center\" label=\"总评分\">\n                  <template slot-scope=\"scope\">\n                       {{scope.row.zongpingfen}}\n                     </template>\n                </el-table-column>\n            <el-table-column width=\"300\" :align=\"contents.tableAlign\"\n                header-align=\"center\"\n                label=\"操作\">\n                <template slot-scope=\"scope\">\n  