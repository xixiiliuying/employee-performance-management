         @click=\"deleteHandler()\"\n            >{{ contents.btnAdAllFont == 1?'删除':'' }}</el-button>\n            <el-button\n              v-if=\"isAuth('jixiaozhibiao','删除') && contents.btnAdAllIcon == 1 && contents.btnAdAllIconPosition == 2 && contents.tableSelection\"\n              :disabled=\"dataListSelections.length <= 0\"\n              type=\"danger\"\n              @click=\"deleteHandler()\"\n            >{{ contents.btnAdAllFont == 1?'删除':'' }}<i class=\"el-icon-delete el-icon--right\" /></el-button>\n            <el-button\n              v-if=\"isAuth('jixiaozhibiao','删除') && contents.btnAdAllIcon == 0 && contents.tableSelection\"\n              :disabled=\"dataListSelections.length <= 0\"\n              type=\"danger\"\n              @click=\"deleteHandler()\"\n            >{{ contents.btnAdAllFont == 1?'删除':'' }}</el-button>\n            <download-excel v-if=\"isAuth('jixiaozhibiao','导出')\" class = \"export-excel-wrapper\" :data = \"dataList\" :fields = \"json_fields\" name = \"绩效指标.xls\">\n              <!-- 导出excel -->\n              <el-button\n                  v-if=\"contents.btnAdAllIcon == 1 && contents.btnAdAllIconPosition == 1\"\n                  type=\"primary\"\n                  icon=\"el-icon-download\"\n              >{{ contents.btnAdAllFont == 1?'导出':'' }}</el-button>\n              <el-button\n                  v-if=\"contents.btnAdAllIcon == 1 && contents.btnAdAllIconPosition == 2\"\n                  type=\"primary\"\n              >{{ contents.btnAdAllFont == 1?'导出':'' }}<i class=\"el-icon-download el-icon--right\" /></el-button>\n              <el-button\n                  v-if=\"contents.btnAdAllIcon == 0\"\n                  type=\"primary\"\n              >{{ contents.btnAdAllFont == 1?'导出':'' }}</el-button>\n            </download-excel>\n            <el-button\n              v-if=\"isAuth('jixiaozhibiao','打印') && contents.btnAdAllIcon == 1 && contents.btnAdAllIconPosition == 1\"\n              type=\"success\"\n           