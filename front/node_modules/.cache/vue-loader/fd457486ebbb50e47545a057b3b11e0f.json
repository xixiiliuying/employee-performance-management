{"remainingRequest":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\project\\java_project\\T021\\front\\src\\views\\home.vue?vue&type=style&index=0&id=7eb2bc79&lang=scss&scoped=true","dependencies":[{"path":"E:\\project\\java_project\\T021\\front\\src\\views\\home.vue","mtime":1762858156542},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\css-loader\\dist\\cjs.js","mtime":1762233495618},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1762233498059},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\postcss-loader\\src\\index.js","mtime":1762233495756},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1762234960396},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1762233496489}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["home.vue"],"names":[],"mappings":";AAomBA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"home.vue","sourceRoot":"src/views","sourcesContent":["<template>\r\n  <div class=\"main-container\">\r\n    <!-- 侧边导航栏 -->\r\n    <nav class=\"shell close\" :class=\"{ 'dark': isDarkMode }\">\r\n      <header>\r\n        <div class=\"image-text\">\r\n          <span class=\"image\">\r\n            <img src=\"@/assets/img/logo.png\" alt=\"系统logo\">\r\n          </span>\r\n          <div class=\"text logo-text\">\r\n            <span class=\"name\">员工绩效系统</span>\r\n            <span class=\"software\">-HR System-</span>\r\n          </div>\r\n        </div>\r\n        <i class=\"iconfont icon-xiangyoujiantou toggle\" @click=\"toggleShell\"></i>\r\n      </header>\r\n      <div class=\"menu-bar\">\r\n        <div class=\"menu\">\r\n          <li class=\"search-box\" @click=\"expandShell\">\r\n            <i class=\"iconfont icon-sousuo icon\"></i>\r\n            <input type=\"text\" placeholder=\"搜索...\" v-model=\"searchText\">\r\n          </li>\r\n          <ul class=\"menu-links\">\r\n            <li class=\"nav-link\" :class=\"{ 'active': activeMenu === 'home' }\">\r\n              <a href=\"#\" @click=\"setActiveMenu('home')\">\r\n                <i class=\"iconfont icon-shouye icon\"></i>\r\n                <span class=\"text nac-text\">首页</span>\r\n              </a>\r\n            </li>\r\n\r\n            <li class=\"nav-link\" :class=\"{ 'active': activeMenu === 'attendance' }\">\r\n              <a href=\"#\" @click=\"setActiveMenu('attendance')\">\r\n                <i class=\"iconfont icon-lishi icon\"></i>\r\n                <span class=\"text nac-text\">考勤管理</span>\r\n              </a>\r\n            </li>\r\n\r\n            <li class=\"nav-link\" :class=\"{ 'active': activeMenu === 'performance' }\">\r\n              <a href=\"#\" @click=\"setActiveMenu('performance')\">\r\n                <i class=\"iconfont icon-chuangzuo icon\"></i>\r\n                <span class=\"text nac-text\">绩效考核</span>\r\n              </a>\r\n            </li>\r\n\r\n            <li class=\"nav-link\" :class=\"{ 'active': activeMenu === 'salary' }\">\r\n              <a href=\"#\" @click=\"setActiveMenu('salary')\">\r\n                <i class=\"iconfont icon-xiaoxi icon\"></i>\r\n                <span class=\"text nac-text\">薪资管理</span>\r\n              </a>\r\n            </li>\r\n\r\n            <li class=\"nav-link\" :class=\"{ 'active': activeMenu === 'leave' }\">\r\n              <a href=\"#\" @click=\"setActiveMenu('leave')\">\r\n                <i class=\"iconfont icon-shoucangxiao icon\"></i>\r\n                <span class=\"text nac-text\">请假审批</span>\r\n              </a>\r\n            </li>\r\n\r\n            <li class=\"nav-link\" :class=\"{ 'active': activeMenu === 'hr' }\" v-if=\"userInfo && userInfo.role === 'hr'\">\r\n              <a href=\"#\" @click=\"setActiveMenu('hr')\">\r\n                <i class=\"iconfont icon-fensi icon\"></i>\r\n                <span class=\"text nac-text\">HR管理</span>\r\n              </a>\r\n            </li>\r\n          </ul>\r\n        </div>\r\n        <div class=\"bottom-content\">\r\n          <li class=\"nav-link\" @click=\"logout\">\r\n            <a href=\"#\">\r\n              <i class=\"iconfont icon-zhuxiaoyuan icon\"></i>\r\n              <span class=\"text nac-text\">注销登录</span>\r\n            </a>\r\n          </li>\r\n          <li class=\"mode\">\r\n            <div class=\"sun-moon\">\r\n              <i class=\"iconfont icon-rijian icon sun\"></i>\r\n              <i class=\"iconfont icon-yejian icon moon\"></i>\r\n            </div>\r\n            <span class=\"mode-text text\">{{ isDarkMode ? '白日模式' : '夜间模式' }}</span>\r\n            <div class=\"toggle-switch\" @click=\"toggleDarkMode\">\r\n              <span class=\"switch\"></span>\r\n            </div>\r\n          </li>\r\n        </div>\r\n      </div>\r\n    </nav>\r\n\r\n    <!-- 主内容区域 -->\r\n    <div class=\"main-content\" :class=\"{ 'collapsed': isShellCollapsed }\">\r\n      <!-- 加载状态 -->\r\n      <div v-if=\"loading\" class=\"loading-container\">\r\n        <el-card>\r\n          <div class=\"loading-content\">\r\n            <i class=\"el-icon-loading\"></i>\r\n            <span>正在加载用户信息...</span>\r\n          </div>\r\n        </el-card>\r\n      </div>\r\n\r\n      <!-- 错误状态 -->\r\n      <div v-else-if=\"error\" class=\"error-container\">\r\n        <el-card>\r\n          <div class=\"error-content\">\r\n            <i class=\"el-icon-error\"></i>\r\n            <span>{{ errorMessage }}</span>\r\n            <el-button type=\"primary\" @click=\"retryLoad\" style=\"margin-top: 10px;\">\r\n              重新加载\r\n            </el-button>\r\n          </div>\r\n        </el-card>\r\n      </div>\r\n\r\n      <!-- 正常显示内容 -->\r\n      <div v-else class=\"content\">\r\n        <div class=\"welcome-section\">\r\n          <div class=\"main-text\">欢迎使用 员工绩效考核管理系统</div>\r\n          <div class=\"sub-text\" v-if=\"userInfo\">欢迎回来，{{ userInfo.sname }}！</div>\r\n        </div>\r\n\r\n        <!-- 用户信息卡片 -->\r\n        <div class=\"info-cards\" v-if=\"userInfo\">\r\n          <el-row :gutter=\"20\">\r\n            <!-- 基本信息卡片 -->\r\n            <el-col :span=\"8\">\r\n              <el-card class=\"info-card\">\r\n                <div slot=\"header\" class=\"card-header\">\r\n                  <span>基本信息</span>\r\n                </div>\r\n                <div class=\"card-content\">\r\n                  <div class=\"info-item\">\r\n                    <i class=\"el-icon-user\"></i>\r\n                    <span>员工号：{{ userInfo.sid }}</span>\r\n                  </div>\r\n                  <div class=\"info-item\">\r\n                    <i class=\"el-icon-male\" v-if=\"userInfo.gender === '男'\"></i>\r\n                    <i class=\"el-icon-female\" v-else></i>\r\n                    <span>性别：{{ userInfo.gender }}</span>\r\n                  </div>\r\n                  <div class=\"info-item\">\r\n                    <i class=\"el-icon-s-custom\"></i>\r\n                    <span>角色：{{ roleText }}</span>\r\n                  </div>\r\n                  <div class=\"info-item\">\r\n                    <i class=\"el-icon-date\"></i>\r\n                    <span>入职日期：{{ formatDate(userInfo.hireDate) }}</span>\r\n                  </div>\r\n                </div>\r\n              </el-card>\r\n            </el-col>\r\n\r\n            <!-- 部门信息卡片 -->\r\n            <el-col :span=\"8\">\r\n              <el-card class=\"info-card\">\r\n                <div slot=\"header\" class=\"card-header\">\r\n                  <span>部门信息</span>\r\n                </div>\r\n                <div class=\"card-content\">\r\n                  <div class=\"info-item\">\r\n                    <i class=\"el-icon-office-building\"></i>\r\n                    <span>部门：{{ departmentName }}</span>\r\n                  </div>\r\n                  <div class=\"info-item\">\r\n                    <i class=\"el-icon-suitcase\"></i>\r\n                    <span>岗位：{{ jobName }}</span>\r\n                  </div>\r\n                  <div class=\"info-item\">\r\n                    <i class=\"el-icon-phone\"></i>\r\n                    <span>电话：{{ userInfo.phone || '未设置' }}</span>\r\n                  </div>\r\n                  <div class=\"info-item\">\r\n                    <i class=\"el-icon-message\"></i>\r\n                    <span>邮箱：{{ userInfo.email || '未设置' }}</span>\r\n                  </div>\r\n                </div>\r\n              </el-card>\r\n            </el-col>\r\n\r\n            <!-- 快捷操作卡片 -->\r\n            <el-col :span=\"8\">\r\n              <el-card class=\"info-card\">\r\n                <div slot=\"header\" class=\"card-header\">\r\n                  <span>快捷操作</span>\r\n                </div>\r\n                <div class=\"card-content quick-actions\">\r\n                  <el-button\r\n                      type=\"primary\"\r\n                      icon=\"el-icon-edit\"\r\n                      @click=\"goToProfile\"\r\n                      class=\"action-btn\">\r\n                    修改个人信息\r\n                  </el-button>\r\n\r\n                  <el-button\r\n                      type=\"success\"\r\n                      icon=\"el-icon-time\"\r\n                      @click=\"goToAttendance\"\r\n                      class=\"action-btn\">\r\n                    考勤打卡\r\n                  </el-button>\r\n\r\n                  <el-button\r\n                      type=\"warning\"\r\n                      icon=\"el-icon-tickets\"\r\n                      @click=\"goToLeave\"\r\n                      class=\"action-btn\">\r\n                    请假申请\r\n                  </el-button>\r\n\r\n                  <el-button\r\n                      type=\"info\"\r\n                      icon=\"el-icon-money\"\r\n                      @click=\"goToSalary\"\r\n                      class=\"action-btn\">\r\n                    我的薪资\r\n                  </el-button>\r\n\r\n                  <!-- HR专属功能 -->\r\n                  <template v-if=\"userInfo.role === 'hr'\">\r\n                    <el-button\r\n                        type=\"danger\"\r\n                        icon=\"el-icon-s-check\"\r\n                        @click=\"goToHRManage\"\r\n                        class=\"action-btn\">\r\n                      HR管理\r\n                    </el-button>\r\n                  </template>\r\n                </div>\r\n              </el-card>\r\n            </el-col>\r\n          </el-row>\r\n        </div>\r\n\r\n        <!-- 系统统计信息（HR可见） -->\r\n        <div class=\"stats-section\" v-if=\"userInfo && userInfo.role === 'hr'\">\r\n          <el-card>\r\n            <div slot=\"header\" class=\"stats-header\">\r\n              <span>系统统计</span>\r\n            </div>\r\n            <el-row :gutter=\"20\">\r\n              <el-col :span=\"6\">\r\n                <div class=\"stat-item\">\r\n                  <div class=\"stat-value\">{{ stats.totalStaff || 0 }}</div>\r\n                  <div class=\"stat-label\">员工总数</div>\r\n                </div>\r\n              </el-col>\r\n              <el-col :span=\"6\">\r\n                <div class=\"stat-item\">\r\n                  <div class=\"stat-value\">{{ stats.pendingLeave || 0 }}</div>\r\n                  <div class=\"stat-label\">待审批请假</div>\r\n                </div>\r\n              </el-col>\r\n              <el-col :span=\"6\">\r\n                <div class=\"stat-item\">\r\n                  <div class=\"stat-value\">{{ stats.todayAttendance || 0 }}</div>\r\n                  <div class=\"stat-label\">今日打卡</div>\r\n                </div>\r\n              </el-col>\r\n              <el-col :span=\"6\">\r\n                <div class=\"stat-item\">\r\n                  <div class=\"stat-value\">{{ stats.unpaidSalary || 0 }}</div>\r\n                  <div class=\"stat-label\">待发薪资</div>\r\n                </div>\r\n              </el-col>\r\n            </el-row>\r\n          </el-card>\r\n        </div>\r\n\r\n        <!-- 公告信息 -->\r\n        <div class=\"notice-section\" v-if=\"notices.length > 0\">\r\n          <el-card>\r\n            <div slot=\"header\" class=\"notice-header\">\r\n              <span>最新公告</span>\r\n            </div>\r\n            <div class=\"notice-list\">\r\n              <div v-for=\"notice in notices\" :key=\"notice.id\" class=\"notice-item\">\r\n                <div class=\"notice-title\">{{ notice.title }}</div>\r\n                <div class=\"notice-time\">{{ formatDate(notice.createTime) }}</div>\r\n              </div>\r\n            </div>\r\n          </el-card>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'Home',\r\n  data() {\r\n    return {\r\n      userInfo: null,\r\n      departmentName: '加载中...',\r\n      jobName: '加载中...',\r\n      notices: [],\r\n      stats: {\r\n        totalStaff: 0,\r\n        pendingLeave: 0,\r\n        todayAttendance: 0,\r\n        unpaidSalary: 0\r\n      },\r\n      loading: false,\r\n      error: false,\r\n      errorMessage: '',\r\n      isShellCollapsed: true,\r\n      isDarkMode: false,\r\n      activeMenu: 'home',\r\n      searchText: ''\r\n    }\r\n  },\r\n  computed: {\r\n    roleText() {\r\n      if (!this.userInfo) return ''\r\n      return this.userInfo.role === 'hr' ? 'HR管理员' : '员工'\r\n    }\r\n  },\r\n  mounted() {\r\n    this.init()\r\n  },\r\n  methods: {\r\n    async init() {\r\n      await this.loadUserInfo()\r\n    },\r\n\r\n    // 导航栏控制方法\r\n    toggleShell() {\r\n      this.isShellCollapsed = !this.isShellCollapsed\r\n    },\r\n\r\n    expandShell() {\r\n      this.isShellCollapsed = false\r\n    },\r\n\r\n    setActiveMenu(menu) {\r\n      this.activeMenu = menu\r\n      // 这里可以添加路由跳转逻辑\r\n      switch(menu) {\r\n        case 'attendance':\r\n          this.goToAttendance()\r\n          break\r\n        case 'performance':\r\n          // 跳转到绩效考核页面\r\n          break\r\n        case 'salary':\r\n          this.goToSalary()\r\n          break\r\n        case 'leave':\r\n          this.goToLeave()\r\n          break\r\n        case 'hr':\r\n          this.goToHRManage()\r\n          break\r\n        default:\r\n          // 首页不需要跳转\r\n          break\r\n      }\r\n    },\r\n\r\n    toggleDarkMode() {\r\n      this.isDarkMode = !this.isDarkMode\r\n    },\r\n\r\n    logout() {\r\n      this.$confirm('确定要退出登录吗?', '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }).then(() => {\r\n        this.$storage.remove('Token')\r\n        this.$storage.remove('role')\r\n        this.$storage.remove('sessionTable')\r\n        this.$router.push({ name: 'login' })\r\n      })\r\n    },\r\n\r\n    // 加载用户信息\r\n    async loadUserInfo() {\r\n      this.loading = true\r\n      this.error = false\r\n\r\n      try {\r\n        console.log('开始加载用户信息...')\r\n\r\n        // 检查Token\r\n        const token = this.$storage?.get('Token')\r\n        if (!token) {\r\n          this.error = true\r\n          this.errorMessage = '未检测到登录状态，请重新登录'\r\n          return\r\n        }\r\n\r\n        // 1. 获取用户基本信息\r\n        const { data: userData } = await this.$http({\r\n          url: this.$api.url.user.session,\r\n          method: \"get\"\r\n        })\r\n\r\n        if (userData && userData.code === 0) {\r\n          this.userInfo = userData.data\r\n          console.log('用户信息加载成功:', this.userInfo)\r\n\r\n          // 2. 并行加载其他信息\r\n          await Promise.all([\r\n            this.loadDepartmentAndJobInfo(),\r\n            this.loadNotices(),\r\n            this.userInfo.role === 'hr' ? this.loadHRStats() : Promise.resolve()\r\n          ])\r\n\r\n        } else {\r\n          this.error = true\r\n          this.errorMessage = userData?.msg || '获取用户信息失败'\r\n        }\r\n      } catch (error) {\r\n        this.error = true\r\n        this.errorMessage = '网络错误，请检查网络连接'\r\n        console.error('加载用户信息失败:', error)\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    // 加载部门和岗位信息\r\n    async loadDepartmentAndJobInfo() {\r\n      try {\r\n        // 加载部门信息\r\n        if (this.userInfo.deptId) {\r\n          const deptRes = await this.$http({\r\n            url: this.$api.buildUrl(this.$api.url.department.info, { id: this.userInfo.deptId }),\r\n            method: \"get\"\r\n          })\r\n          if (deptRes.data && deptRes.data.code === 0) {\r\n            this.departmentName = deptRes.data.data.dname\r\n          } else {\r\n            this.departmentName = '未知部门'\r\n          }\r\n        }\r\n\r\n        // 加载岗位信息\r\n        if (this.userInfo.jobId) {\r\n          const jobRes = await this.$http({\r\n            url: this.$api.buildUrl(this.$api.url.job.info, { id: this.userInfo.jobId }),\r\n            method: \"get\"\r\n          })\r\n          if (jobRes.data && jobRes.data.code === 0) {\r\n            this.jobName = jobRes.data.data.jname\r\n          } else {\r\n            this.jobName = '未知岗位'\r\n          }\r\n        }\r\n      } catch (error) {\r\n        console.error('加载部门岗位信息失败:', error)\r\n        this.departmentName = '加载失败'\r\n        this.jobName = '加载失败'\r\n      }\r\n    },\r\n\r\n    // 加载公告信息\r\n    async loadNotices() {\r\n      try {\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.notice.list,\r\n          method: \"get\",\r\n          params: {\r\n            limit: 5 // 只显示最新5条公告\r\n          }\r\n        })\r\n        if (data && data.code === 0) {\r\n          this.notices = data.data || []\r\n        }\r\n      } catch (error) {\r\n        console.error('加载公告信息失败:', error)\r\n        this.notices = []\r\n      }\r\n    },\r\n\r\n    // 加载HR统计信息\r\n    async loadHRStats() {\r\n      try {\r\n        console.log('开始加载HR统计信息...')\r\n\r\n        // 并行加载所有统计信息\r\n        await Promise.all([\r\n          this.loadTotalStaff(),\r\n          this.loadPendingLeave(),\r\n          this.loadTodayAttendance(),\r\n          this.loadUnpaidSalary()\r\n        ])\r\n\r\n      } catch (error) {\r\n        console.error('加载统计信息失败:', error)\r\n      }\r\n    },\r\n\r\n    // 获取员工总数\r\n    async loadTotalStaff() {\r\n      try {\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.user.list,\r\n          method: \"get\"\r\n        })\r\n        if (data && data.code === 0) {\r\n          this.stats.totalStaff = data.data.length || 0\r\n        }\r\n      } catch (error) {\r\n        console.error('获取员工总数失败:', error)\r\n        this.stats.totalStaff = 0\r\n      }\r\n    },\r\n\r\n    // 获取待审批请假数量\r\n    async loadPendingLeave() {\r\n      try {\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.hrLeave.pendingList,\r\n          method: \"get\"\r\n        })\r\n        if (data && data.code === 0) {\r\n          this.stats.pendingLeave = data.data.length || 0\r\n        }\r\n      } catch (error) {\r\n        console.error('获取待审批请假数量失败:', error)\r\n        this.stats.pendingLeave = 0\r\n      }\r\n    },\r\n\r\n    // 获取今日打卡人数\r\n    async loadTodayAttendance() {\r\n      try {\r\n        const today = new Date().toISOString().split('T')[0]\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.attendance.list,\r\n          method: \"get\",\r\n          params: {\r\n            date: today\r\n          }\r\n        })\r\n        if (data && data.code === 0) {\r\n          // 假设数据结构为数组，计算今日打卡人数\r\n          const todayRecords = data.data.filter(record =>\r\n              record.checkInTime && record.checkInTime.startsWith(today)\r\n          )\r\n          this.stats.todayAttendance = todayRecords.length || 0\r\n        } else {\r\n          // 如果没有数据，使用默认值\r\n          this.stats.todayAttendance = 0\r\n        }\r\n      } catch (error) {\r\n        console.error('获取今日打卡人数失败:', error)\r\n        this.stats.todayAttendance = 0\r\n      }\r\n    },\r\n\r\n    // 获取待发薪资数量\r\n    async loadUnpaidSalary() {\r\n      try {\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.salary.list,\r\n          method: \"get\"\r\n        })\r\n        if (data && data.code === 0) {\r\n          // 假设薪资记录中有状态字段，筛选未发放的\r\n          const unpaidSalaries = data.data.filter(salary =>\r\n              salary.status === 'pending' || salary.status === 'calculated'\r\n          )\r\n          this.stats.unpaidSalary = unpaidSalaries.length || 0\r\n        } else {\r\n          this.stats.unpaidSalary = 0\r\n        }\r\n      } catch (error) {\r\n        console.error('获取待发薪资数量失败:', error)\r\n        this.stats.unpaidSalary = 0\r\n      }\r\n    },\r\n\r\n    retryLoad() {\r\n      this.loadUserInfo()\r\n    },\r\n\r\n    formatDate(date) {\r\n      if (!date) return '未设置'\r\n      try {\r\n        return new Date(date).toLocaleDateString('zh-CN')\r\n      } catch (e) {\r\n        return '日期格式错误'\r\n      }\r\n    },\r\n\r\n    // 快捷操作方法\r\n    goToProfile() {\r\n      this.$router.push('/center')\r\n    },\r\n\r\n    goToAttendance() {\r\n      this.$router.push('/attendance')\r\n    },\r\n\r\n    goToLeave() {\r\n      this.$router.push('/leave')\r\n    },\r\n\r\n    goToSalary() {\r\n      this.$router.push('/salary')\r\n    },\r\n\r\n    goToHRManage() {\r\n      this.$router.push('/hr/manage')\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.main-container {\r\n  display: flex;\r\n  min-height: 100vh;\r\n  background-color: var(--body-color);\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n/* 设置全局变量 */\r\n:root {\r\n  --body-color: #E4E9F7;\r\n  --shell-color: #FFF;\r\n  --primary-color: #695CFE;\r\n  --primary-color-light: #F6F5FF;\r\n  --toggle-color: #DDD;\r\n  --text-color: #707070;\r\n}\r\n\r\n/* 深色主题变量 */\r\n.dark {\r\n  --body-color: #202224;\r\n  --shell-color: #171717;\r\n  --primary-color: #3a3b3c;\r\n  --primary-color-light: #3a3b3c;\r\n  --toggle-color: #fff;\r\n  --text-color: #ccc;\r\n}\r\n\r\n/* 导航栏样式 */\r\n.shell {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  height: 100%;\r\n  width: 250px;\r\n  padding: 10px 14px;\r\n  background: var(--shell-color);\r\n  transition: all 0.3s ease;\r\n  z-index: 100;\r\n  box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.shell.close {\r\n  width: 88px;\r\n}\r\n\r\n.shell li {\r\n  height: 50px;\r\n  list-style: none;\r\n  display: flex;\r\n  align-items: center;\r\n  margin-top: 10px;\r\n}\r\n\r\n.image, .icon {\r\n  min-width: 60px;\r\n  border-radius: 6px;\r\n}\r\n\r\n.icon {\r\n  min-width: 60px;\r\n  border-radius: 6px;\r\n  height: 100%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 23px;\r\n}\r\n\r\n.text, .icon {\r\n  color: var(--text-color);\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.text {\r\n  font-weight: 500;\r\n  font-size: 17px;\r\n  white-space: nowrap;\r\n  opacity: 1;\r\n}\r\n\r\n.shell.close .text {\r\n  opacity: 0;\r\n}\r\n\r\nheader {\r\n  position: relative;\r\n}\r\n\r\n.image-text {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.logo-text {\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.name {\r\n  margin-top: 2px;\r\n  font-weight: 600;\r\n  font-size: 18px;\r\n}\r\n\r\n.software {\r\n  font-size: 12px;\r\n  margin-top: -2px;\r\n  display: block;\r\n}\r\n\r\n.image {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.image img {\r\n  width: 45px;\r\n  border-radius: 6px;\r\n}\r\n\r\n.toggle {\r\n  position: absolute;\r\n  top: 50%;\r\n  right: -25px;\r\n  transform: translateY(-50%) rotate(180deg);\r\n  height: 25px;\r\n  width: 25px;\r\n  background-color: var(--primary-color);\r\n  color: var(--shell-color);\r\n  border-radius: 50%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 15px;\r\n  cursor: pointer;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.shell.close .toggle {\r\n  transform: translateY(-50%) rotate(0deg);\r\n}\r\n\r\n.menu {\r\n  margin-top: 40px;\r\n}\r\n\r\nli.search-box {\r\n  border-radius: 6px;\r\n  background-color: var(--primary-color-light);\r\n  cursor: pointer;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\nli.search-box input {\r\n  height: 100%;\r\n  width: 100%;\r\n  outline: none;\r\n  border: none;\r\n  background-color: var(--primary-color-light);\r\n  color: var(--text-color);\r\n  border-radius: 6px;\r\n  font-size: 17px;\r\n  font-weight: 500;\r\n  transition: all 0.3s ease;\r\n  padding: 0 10px;\r\n}\r\n\r\n.shell li a {\r\n  list-style: none;\r\n  height: 100%;\r\n  background-color: transparent;\r\n  display: flex;\r\n  align-items: center;\r\n  height: 100%;\r\n  width: 100%;\r\n  border-radius: 6px;\r\n  text-decoration: none;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.shell li a:hover {\r\n  background-color: var(--primary-color);\r\n}\r\n\r\n.shell li a:hover .icon,\r\n.shell li a:hover .text {\r\n  color: var(--shell-color);\r\n}\r\n\r\n.nav-link.active a {\r\n  background-color: var(--primary-color);\r\n}\r\n\r\n.nav-link.active .icon,\r\n.nav-link.active .text {\r\n  color: var(--shell-color);\r\n}\r\n\r\n.menu-bar {\r\n  height: calc(100% - 55px);\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: space-between;\r\n  overflow-y: scroll;\r\n}\r\n\r\n.menu-bar::-webkit-scrollbar {\r\n  display: none;\r\n}\r\n\r\n.menu-bar .mode {\r\n  border-radius: 6px;\r\n  background-color: var(--primary-color-light);\r\n  position: relative;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.menu-bar .mode .sun-moon {\r\n  height: 50px;\r\n  width: 60px;\r\n}\r\n\r\n.mode .sun-moon i {\r\n  position: absolute;\r\n}\r\n\r\n.mode .sun-moon i.sun {\r\n  opacity: 0;\r\n}\r\n\r\n.toggle-switch {\r\n  position: absolute;\r\n  right: 0;\r\n  height: 100%;\r\n  min-width: 60px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  border-radius: 6px;\r\n  cursor: pointer;\r\n}\r\n\r\n.switch {\r\n  position: relative;\r\n  height: 22px;\r\n  width: 40px;\r\n  border-radius: 25px;\r\n  background-color: var(--toggle-color);\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.switch::before {\r\n  content: '';\r\n  position: absolute;\r\n  height: 15px;\r\n  width: 15px;\r\n  border-radius: 50%;\r\n  top: 50%;\r\n  left: 5px;\r\n  transform: translateY(-50%);\r\n  background-color: var(--shell-color);\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.dark .shell li a:hover .icon,\r\n.dark .shell li a:hover .text {\r\n  color: #ccc;\r\n}\r\n\r\n.dark .mode .sun-moon i.sun {\r\n  opacity: 1;\r\n}\r\n\r\n.dark .mode .sun-moon i.moon {\r\n  opacity: 0;\r\n}\r\n\r\n.dark .switch::before {\r\n  left: 20px;\r\n}\r\n\r\n/* 主内容区域样式 */\r\n.main-content {\r\n  flex: 1;\r\n  margin-left: 250px;\r\n  padding: 20px;\r\n  transition: all 0.3s ease;\r\n  min-height: 100vh;\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n}\r\n\r\n.main-content.collapsed {\r\n  margin-left: 88px;\r\n}\r\n\r\n.dark .main-content {\r\n  background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);\r\n}\r\n\r\n/* 原有的内容样式保持不变 */\r\n.home-container {\r\n  padding: 20px;\r\n  min-height: calc(100vh - 60px);\r\n\r\n  .loading-container, .error-container {\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n    height: 200px;\r\n\r\n    .loading-content, .error-content {\r\n      text-align: center;\r\n\r\n      i {\r\n        font-size: 40px;\r\n        margin-bottom: 10px;\r\n        display: block;\r\n        color: #409eff;\r\n      }\r\n\r\n      span {\r\n        font-size: 16px;\r\n        color: #606266;\r\n      }\r\n    }\r\n  }\r\n\r\n  .content {\r\n    .welcome-section {\r\n      text-align: center;\r\n      margin-bottom: 40px;\r\n      color: white;\r\n\r\n      .main-text {\r\n        font-size: 36px;\r\n        font-weight: bold;\r\n        margin-bottom: 10px;\r\n        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);\r\n      }\r\n\r\n      .sub-text {\r\n        font-size: 20px;\r\n        opacity: 0.9;\r\n        text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);\r\n      }\r\n    }\r\n\r\n    .info-cards {\r\n      margin-bottom: 30px;\r\n\r\n      .info-card {\r\n        height: 100%;\r\n        transition: transform 0.3s ease, box-shadow 0.3s ease;\r\n\r\n        &:hover {\r\n          transform: translateY(-5px);\r\n          box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);\r\n        }\r\n\r\n        .card-header {\r\n          font-weight: bold;\r\n          color: #303133;\r\n          border-bottom: 1px solid #e6ebf5;\r\n          padding: 15px 20px;\r\n          background-color: #f5f7fa;\r\n        }\r\n\r\n        .card-content {\r\n          padding: 20px;\r\n\r\n          .info-item {\r\n            display: flex;\r\n            align-items: center;\r\n            margin-bottom: 15px;\r\n            padding: 8px 0;\r\n\r\n            i {\r\n              margin-right: 10px;\r\n              color: #409eff;\r\n              font-size: 16px;\r\n              width: 20px;\r\n            }\r\n\r\n            span {\r\n              color: #606266;\r\n              font-size: 14px;\r\n            }\r\n          }\r\n\r\n          .quick-actions {\r\n            display: flex;\r\n            flex-direction: column;\r\n            gap: 12px;\r\n\r\n            .action-btn {\r\n              width: 100%;\r\n              justify-content: flex-start;\r\n              padding: 12px 20px;\r\n            }\r\n          }\r\n        }\r\n      }\r\n    }\r\n\r\n    .stats-section {\r\n      margin-bottom: 30px;\r\n\r\n      .stats-header {\r\n        font-weight: bold;\r\n        color: #303133;\r\n        padding: 15px 20px;\r\n        background-color: #f5f7fa;\r\n        border-bottom: 1px solid #e6ebf5;\r\n      }\r\n\r\n      .stat-item {\r\n        text-align: center;\r\n        padding: 20px 0;\r\n\r\n        .stat-value {\r\n          font-size: 32px;\r\n          font-weight: bold;\r\n          color: #409eff;\r\n          margin-bottom: 8px;\r\n        }\r\n\r\n        .stat-label {\r\n          font-size: 14px;\r\n          color: #909399;\r\n        }\r\n      }\r\n    }\r\n\r\n    .notice-section {\r\n      .notice-header {\r\n        font-weight: bold;\r\n        color: #303133;\r\n        padding: 15px 20px;\r\n        background-color: #f5f7fa;\r\n        border-bottom: 1px solid #e6ebf5;\r\n      }\r\n\r\n      .notice-list {\r\n        padding: 20px;\r\n\r\n        .notice-item {\r\n          display: flex;\r\n          justify-content: space-between;\r\n          align-items: center;\r\n          padding: 12px 0;\r\n          border-bottom: 1px solid #f0f0f0;\r\n\r\n          &:last-child {\r\n            border-bottom: none;\r\n          }\r\n\r\n          .notice-title {\r\n            font-size: 14px;\r\n            color: #606266;\r\n            flex: 1;\r\n          }\r\n\r\n          .notice-time {\r\n            font-size: 12px;\r\n            color: #909399;\r\n          }\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n// 响应式设计\r\n@media (max-width: 768px) {\r\n  .shell {\r\n    width: 88px;\r\n  }\r\n\r\n  .shell.close {\r\n    width: 0;\r\n    padding: 0;\r\n  }\r\n\r\n  .main-content {\r\n    margin-left: 88px;\r\n    padding: 15px;\r\n  }\r\n\r\n  .main-content.collapsed {\r\n    margin-left: 0;\r\n  }\r\n\r\n  .home-container {\r\n    padding: 15px;\r\n\r\n    .content {\r\n      .welcome-section {\r\n        .main-text {\r\n          font-size: 28px;\r\n        }\r\n\r\n        .sub-text {\r\n          font-size: 16px;\r\n        }\r\n      }\r\n\r\n      .info-cards {\r\n        .el-col {\r\n          margin-bottom: 20px;\r\n        }\r\n      }\r\n\r\n      .stats-section {\r\n        .el-col {\r\n          margin-bottom: 15px;\r\n        }\r\n\r\n        .stat-item {\r\n          .stat-value {\r\n            font-size: 24px;\r\n          }\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n</style>"]}]}