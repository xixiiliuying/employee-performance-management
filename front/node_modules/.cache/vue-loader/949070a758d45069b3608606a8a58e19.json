{"remainingRequest":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\project\\java_project\\T021\\front\\src\\views\\home.vue?vue&type=script&lang=js","dependencies":[{"path":"E:\\project\\java_project\\T021\\front\\src\\views\\home.vue","mtime":1762859125367},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\babel-loader\\lib\\index.js","mtime":1762233498302},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1762233496489}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["home.vue"],"names":[],"mappings":";AA+HA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"home.vue","sourceRoot":"src/views","sourcesContent":["<template>\r\n  <div class=\"main-container\">\r\n    <!-- 侧边导航栏 -->\r\n    <nav class=\"shell\" :class=\"{ 'close': isShellCollapsed, 'dark': isDarkMode }\">\r\n      <header>\r\n        <div class=\"image-text\">\r\n          <span class=\"image\">\r\n            <img src=\"@/assets/img/logo.png\" alt=\"系统logo\">\r\n          </span>\r\n          <div class=\"text logo-text\">\r\n            <span class=\"name\">员工绩效系统</span>\r\n            <span class=\"software\">-HR System-</span>\r\n          </div>\r\n        </div>\r\n        <i class=\"iconfont icon-xiangyoujiantou toggle\" @click=\"toggleShell\"></i>\r\n      </header>\r\n      <div class=\"menu-bar\">\r\n        <div class=\"menu\">\r\n          <li class=\"search-box\" @click=\"expandShell\">\r\n            <i class=\"iconfont icon-sousuo icon\"></i>\r\n            <input type=\"text\" placeholder=\"搜索...\" v-model=\"searchText\" @keyup.enter=\"handleSearch\">\r\n          </li>\r\n          <ul class=\"menu-links\">\r\n            <!-- 员工通用菜单 -->\r\n            <li class=\"nav-link\" :class=\"{ 'active': $route.path === '/home' }\">\r\n              <router-link to=\"/home\">\r\n                <i class=\"iconfont icon-shouye icon\"></i>\r\n                <span class=\"text nac-text\">首页概览</span>\r\n              </router-link>\r\n            </li>\r\n\r\n            <li class=\"nav-link\" :class=\"{ 'active': $route.path.includes('/attendance') }\">\r\n              <router-link to=\"/attendance\">\r\n                <i class=\"iconfont icon-lishi icon\"></i>\r\n                <span class=\"text nac-text\">考勤打卡</span>\r\n              </router-link>\r\n            </li>\r\n\r\n            <li class=\"nav-link\" :class=\"{ 'active': $route.path.includes('/salary') }\">\r\n              <router-link to=\"/salary\">\r\n                <i class=\"iconfont icon-xiaoxi icon\"></i>\r\n                <span class=\"text nac-text\">薪资查询</span>\r\n              </router-link>\r\n            </li>\r\n\r\n            <li class=\"nav-link\" :class=\"{ 'active': $route.path.includes('/leave') }\">\r\n              <router-link to=\"/leave\">\r\n                <i class=\"iconfont icon-shoucangxiao icon\"></i>\r\n                <span class=\"text nac-text\">请假申请</span>\r\n              </router-link>\r\n            </li>\r\n\r\n            <li class=\"nav-link\" :class=\"{ 'active': $route.path.includes('/notice') }\">\r\n              <router-link to=\"/notice\">\r\n                <i class=\"iconfont icon-chuangzuo icon\"></i>\r\n                <span class=\"text nac-text\">公告查看</span>\r\n              </router-link>\r\n            </li>\r\n\r\n            <li class=\"nav-link\" :class=\"{ 'active': $route.path.includes('/profile') }\">\r\n              <router-link to=\"/center\">\r\n                <i class=\"iconfont icon-fensi icon\"></i>\r\n                <span class=\"text nac-text\">个人信息</span>\r\n              </router-link>\r\n            </li>\r\n\r\n            <!-- HR专属菜单 -->\r\n            <template v-if=\"userInfo && userInfo.role === 'hr'\">\r\n              <li class=\"nav-divider\">\r\n                <span class=\"divider-text\">HR管理</span>\r\n              </li>\r\n\r\n              <li class=\"nav-link\" :class=\"{ 'active': $route.path.includes('/hr/attendance') }\">\r\n                <router-link to=\"/hr/attendance\">\r\n                  <i class=\"iconfont icon-tongji icon\"></i>\r\n                  <span class=\"text nac-text\">考勤统计</span>\r\n                </router-link>\r\n              </li>\r\n\r\n              <li class=\"nav-link\" :class=\"{ 'active': $route.path.includes('/hr/leave') }\">\r\n                <router-link to=\"/hr/leave\">\r\n                  <i class=\"iconfont icon-shenpi icon\"></i>\r\n                  <span class=\"text nac-text\">请假审批</span>\r\n                </router-link>\r\n              </li>\r\n\r\n              <li class=\"nav-link\" :class=\"{ 'active': $route.path.includes('/hr/salary') }\">\r\n                <router-link to=\"/hr/salary\">\r\n                  <i class=\"iconfont icon-gongzi icon\"></i>\r\n                  <span class=\"text nac-text\">薪资管理</span>\r\n                </router-link>\r\n              </li>\r\n\r\n              <li class=\"nav-link\" :class=\"{ 'active': $route.path.includes('/hr/employee') }\">\r\n                <router-link to=\"/hr/employee\">\r\n                  <i class=\"iconfont icon-renyuan icon\"></i>\r\n                  <span class=\"text nac-text\">员工管理</span>\r\n                </router-link>\r\n              </li>\r\n            </template>\r\n          </ul>\r\n        </div>\r\n        <div class=\"bottom-content\">\r\n          <li class=\"nav-link\" @click=\"toggleDarkMode\">\r\n            <a href=\"javascript:void(0)\">\r\n              <i class=\"iconfont\" :class=\"isDarkMode ? 'icon-rijian' : 'icon-yejian'\"></i>\r\n              <span class=\"text nac-text\">{{ isDarkMode ? '白天模式' : '夜间模式' }}</span>\r\n            </a>\r\n          </li>\r\n          <li class=\"nav-link\" @click=\"logout\">\r\n            <a href=\"javascript:void(0)\">\r\n              <i class=\"iconfont icon-zhuxiaoyuan icon\"></i>\r\n              <span class=\"text nac-text\">退出登录</span>\r\n            </a>\r\n          </li>\r\n        </div>\r\n      </div>\r\n    </nav>\r\n\r\n    <!-- 主内容区域 -->\r\n    <div class=\"main-content\" :class=\"{ 'collapsed': isShellCollapsed }\">\r\n      <router-view></router-view>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'HomeLayout',\r\n  data() {\r\n    return {\r\n      userInfo: null,\r\n      isShellCollapsed: false,\r\n      isDarkMode: false,\r\n      searchText: '',\r\n      loading: false\r\n    }\r\n  },\r\n  computed: {\r\n    roleText() {\r\n      if (!this.userInfo) return ''\r\n      return this.userInfo.role === 'hr' ? 'HR管理员' : '员工'\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadUserInfo()\r\n    // 从本地存储获取主题设置\r\n    const savedTheme = localStorage.getItem('theme')\r\n    if (savedTheme === 'dark') {\r\n      this.isDarkMode = true\r\n    }\r\n  },\r\n  methods: {\r\n    async loadUserInfo() {\r\n      this.loading = true\r\n      try {\r\n        const token = this.$storage?.get('Token')\r\n        if (!token) {\r\n          this.$router.push({ name: 'login' })\r\n          return\r\n        }\r\n\r\n        const { data } = await this.$http({\r\n          url: this.$api.url.user.session,\r\n          method: \"get\"\r\n        })\r\n\r\n        if (data && data.code === 0) {\r\n          this.userInfo = data.data\r\n        } else {\r\n          this.$message.error(data?.msg || '获取用户信息失败')\r\n          this.logout()\r\n        }\r\n      } catch (error) {\r\n        console.error('加载用户信息失败:', error)\r\n        this.$message.error('网络错误，请重新登录')\r\n        this.logout()\r\n      } finally {\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    toggleShell() {\r\n      this.isShellCollapsed = !this.isShellCollapsed\r\n    },\r\n\r\n    expandShell() {\r\n      this.isShellCollapsed = false\r\n    },\r\n\r\n    toggleDarkMode() {\r\n      this.isDarkMode = !this.isDarkMode\r\n      localStorage.setItem('theme', this.isDarkMode ? 'dark' : 'light')\r\n    },\r\n\r\n    handleSearch() {\r\n      if (this.searchText.trim()) {\r\n        this.$message.info(`搜索: ${this.searchText}`)\r\n        // 这里可以添加搜索逻辑\r\n      }\r\n    },\r\n\r\n    logout() {\r\n      this.$confirm('确定要退出登录吗?', '提示', {\r\n        confirmButtonText: '确定',\r\n        cancelButtonText: '取消',\r\n        type: 'warning'\r\n      }).then(() => {\r\n        this.$storage.remove('Token')\r\n        this.$storage.remove('role')\r\n        this.$storage.remove('sessionTable')\r\n        this.$router.push({ name: 'login' })\r\n      })\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.main-container {\r\n  display: flex;\r\n  min-height: 100vh;\r\n  background-color: var(--body-color);\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n/* 设置全局变量 */\r\n:root {\r\n  --body-color: #E4E9F7;\r\n  --shell-color: #FFF;\r\n  --primary-color: #695CFE;\r\n  --primary-color-light: #F6F5FF;\r\n  --toggle-color: #DDD;\r\n  --text-color: #707070;\r\n}\r\n\r\n/* 深色主题变量 */\r\n.dark {\r\n  --body-color: #202224;\r\n  --shell-color: #171717;\r\n  --primary-color: #3a3b3c;\r\n  --primary-color-light: #3a3b3c;\r\n  --toggle-color: #fff;\r\n  --text-color: #ccc;\r\n}\r\n\r\n/* 导航栏样式 */\r\n.shell {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  height: 100%;\r\n  width: 250px;\r\n  padding: 10px 14px;\r\n  background: var(--shell-color);\r\n  transition: all 0.3s ease;\r\n  z-index: 100;\r\n  box-shadow: 2px 0 10px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.shell.close {\r\n  width: 88px;\r\n}\r\n\r\n.shell li {\r\n  height: 50px;\r\n  list-style: none;\r\n  display: flex;\r\n  align-items: center;\r\n  margin-top: 10px;\r\n}\r\n\r\n.image, .icon {\r\n  min-width: 60px;\r\n  border-radius: 6px;\r\n}\r\n\r\n.icon {\r\n  min-width: 60px;\r\n  border-radius: 6px;\r\n  height: 100%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 20px;\r\n}\r\n\r\n.text, .icon {\r\n  color: var(--text-color);\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.text {\r\n  font-weight: 500;\r\n  font-size: 16px;\r\n  white-space: nowrap;\r\n  opacity: 1;\r\n}\r\n\r\n.shell.close .text {\r\n  opacity: 0;\r\n}\r\n\r\nheader {\r\n  position: relative;\r\n}\r\n\r\n.image-text {\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.logo-text {\r\n  display: flex;\r\n  flex-direction: column;\r\n}\r\n\r\n.name {\r\n  margin-top: 2px;\r\n  font-weight: 600;\r\n  font-size: 18px;\r\n  color: var(--text-color);\r\n}\r\n\r\n.software {\r\n  font-size: 12px;\r\n  margin-top: -2px;\r\n  display: block;\r\n  color: var(--text-color);\r\n  opacity: 0.7;\r\n}\r\n\r\n.image {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.image img {\r\n  width: 45px;\r\n  border-radius: 6px;\r\n}\r\n\r\n.toggle {\r\n  position: absolute;\r\n  top: 50%;\r\n  right: -25px;\r\n  transform: translateY(-50%) rotate(180deg);\r\n  height: 25px;\r\n  width: 25px;\r\n  background-color: var(--primary-color);\r\n  color: var(--shell-color);\r\n  border-radius: 50%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 14px;\r\n  cursor: pointer;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.shell.close .toggle {\r\n  transform: translateY(-50%) rotate(0deg);\r\n}\r\n\r\n.menu {\r\n  margin-top: 40px;\r\n}\r\n\r\nli.search-box {\r\n  border-radius: 6px;\r\n  background-color: var(--primary-color-light);\r\n  cursor: pointer;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\nli.search-box input {\r\n  height: 100%;\r\n  width: 100%;\r\n  outline: none;\r\n  border: none;\r\n  background-color: var(--primary-color-light);\r\n  color: var(--text-color);\r\n  border-radius: 6px;\r\n  font-size: 16px;\r\n  font-weight: 500;\r\n  transition: all 0.3s ease;\r\n  padding: 0 10px;\r\n}\r\n\r\n.shell li a {\r\n  height: 100%;\r\n  background-color: transparent;\r\n  display: flex;\r\n  align-items: center;\r\n  height: 100%;\r\n  width: 100%;\r\n  border-radius: 6px;\r\n  text-decoration: none;\r\n  transition: all 0.3s ease;\r\n  color: inherit;\r\n}\r\n\r\n.shell li a:hover {\r\n  background-color: var(--primary-color);\r\n}\r\n\r\n.shell li a:hover .icon,\r\n.shell li a:hover .text {\r\n  color: var(--shell-color);\r\n}\r\n\r\n.nav-link.active a {\r\n  background-color: var(--primary-color);\r\n}\r\n\r\n.nav-link.active .icon,\r\n.nav-link.active .text {\r\n  color: var(--shell-color);\r\n}\r\n\r\n.nav-divider {\r\n  margin: 20px 0 10px 0;\r\n  height: auto !important;\r\n}\r\n\r\n.divider-text {\r\n  font-size: 12px;\r\n  color: var(--text-color);\r\n  opacity: 0.6;\r\n  text-transform: uppercase;\r\n  letter-spacing: 1px;\r\n}\r\n\r\n.menu-bar {\r\n  height: calc(100% - 55px);\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: space-between;\r\n  overflow-y: auto;\r\n}\r\n\r\n.menu-bar::-webkit-scrollbar {\r\n  display: none;\r\n}\r\n\r\n/* 主内容区域样式 */\r\n.main-content {\r\n  flex: 1;\r\n  margin-left: 250px;\r\n  transition: all 0.3s ease;\r\n  min-height: 100vh;\r\n  background: var(--body-color);\r\n}\r\n\r\n.main-content.collapsed {\r\n  margin-left: 88px;\r\n}\r\n\r\n// 响应式设计\r\n@media (max-width: 768px) {\r\n  .shell {\r\n    width: 88px;\r\n  }\r\n\r\n  .shell.close {\r\n    width: 0;\r\n    padding: 0;\r\n    overflow: hidden;\r\n  }\r\n\r\n  .main-content {\r\n    margin-left: 88px;\r\n  }\r\n\r\n  .main-content.collapsed {\r\n    margin-left: 0;\r\n  }\r\n}\r\n</style>"]}]}