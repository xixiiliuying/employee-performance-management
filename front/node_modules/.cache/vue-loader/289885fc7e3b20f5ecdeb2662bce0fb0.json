{"remainingRequest":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\project\\java_project\\T021\\front\\src\\view\\hr\\NoticeManage.vue?vue&type=style&index=0&id=88da715e&scoped=true&lang=css","dependencies":[{"path":"E:\\project\\java_project\\T021\\front\\src\\view\\hr\\NoticeManage.vue","mtime":1762875747413},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\css-loader\\dist\\cjs.js","mtime":1762233495618},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1762233498059},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\postcss-loader\\src\\index.js","mtime":1762233495756},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1762233497867},{"path":"E:\\project\\java_project\\T021\\front\\node_modules\\vue-loader\\lib\\index.js","mtime":1762233496489}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["NoticeManage.vue"],"names":[],"mappings":";AAiXA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA","file":"NoticeManage.vue","sourceRoot":"src/view/hr","sourcesContent":["<template>\r\n  <div class=\"notice-manage\">\r\n    <div class=\"page-header\">\r\n      <h1>公告管理</h1>\r\n      <p>管理系统公告信息</p>\r\n    </div>\r\n\r\n    <el-card class=\"main-card\">\r\n      <!-- 操作工具栏 -->\r\n      <div class=\"toolbar\">\r\n        <el-button type=\"primary\" icon=\"el-icon-plus\" @click=\"handleAdd\">\r\n          发布公告\r\n        </el-button>\r\n        <el-button type=\"danger\" icon=\"el-icon-delete\" :disabled=\"selectedRows.length === 0\" @click=\"handleBatchDelete\">\r\n          批量删除\r\n        </el-button>\r\n\r\n        <div class=\"search-box\">\r\n          <el-input\r\n              v-model=\"searchKeyword\"\r\n              placeholder=\"搜索公告标题\"\r\n              prefix-icon=\"el-icon-search\"\r\n              style=\"width: 300px\"\r\n              @keyup.enter.native=\"handleSearch\"\r\n          ></el-input>\r\n          <el-button type=\"primary\" @click=\"handleSearch\">搜索</el-button>\r\n        </div>\r\n      </div>\r\n\r\n      <!-- 公告列表 -->\r\n      <el-table\r\n          :data=\"noticeList\"\r\n          v-loading=\"loading\"\r\n          @selection-change=\"handleSelectionChange\"\r\n          style=\"width: 100%\"\r\n      >\r\n        <el-table-column type=\"selection\" width=\"55\"></el-table-column>\r\n        <el-table-column type=\"index\" label=\"序号\" width=\"60\"></el-table-column>\r\n\r\n        <el-table-column prop=\"title\" label=\"公告标题\" min-width=\"200\">\r\n          <template slot-scope=\"{ row }\">\r\n            <span class=\"notice-title\" @click=\"handleView(row)\">{{ row.title }}</span>\r\n            <el-tag v-if=\"row.important\" type=\"danger\" size=\"mini\" style=\"margin-left: 8px\">重要</el-tag>\r\n          </template>\r\n        </el-table-column>\r\n\r\n        <el-table-column prop=\"content\" label=\"公告内容\" min-width=\"300\" show-overflow-tooltip>\r\n        </el-table-column>\r\n\r\n        <el-table-column prop=\"createTime\" label=\"发布时间\" width=\"180\">\r\n        </el-table-column>\r\n\r\n        <el-table-column prop=\"readCount\" label=\"阅读量\" width=\"100\" align=\"center\">\r\n        </el-table-column>\r\n\r\n        <el-table-column label=\"状态\" width=\"100\" align=\"center\">\r\n          <template slot-scope=\"{ row }\">\r\n            <el-tag :type=\"row.status === 'published' ? 'success' : 'warning'\">\r\n              {{ row.status === 'published' ? '已发布' : '草稿' }}\r\n            </el-tag>\r\n          </template>\r\n        </el-table-column>\r\n\r\n        <el-table-column label=\"操作\" width=\"200\" fixed=\"right\">\r\n          <template slot-scope=\"{ row }\">\r\n            <el-button type=\"text\" size=\"small\" @click=\"handleEdit(row)\">\r\n              编辑\r\n            </el-button>\r\n            <el-button type=\"text\" size=\"small\" @click=\"handleView(row)\">\r\n              查看\r\n            </el-button>\r\n            <el-button type=\"text\" size=\"small\" style=\"color: #f56c6c\" @click=\"handleDelete(row)\">\r\n              删除\r\n            </el-button>\r\n          </template>\r\n        </el-table-column>\r\n      </el-table>\r\n\r\n      <!-- 分页 -->\r\n      <div class=\"pagination\">\r\n        <el-pagination\r\n            @size-change=\"handleSizeChange\"\r\n            @current-change=\"handleCurrentChange\"\r\n            :current-page=\"pagination.currentPage\"\r\n            :page-sizes=\"[10, 20, 50, 100]\"\r\n            :page-size=\"pagination.pageSize\"\r\n            layout=\"total, sizes, prev, pager, next, jumper\"\r\n            :total=\"pagination.total\"\r\n        ></el-pagination>\r\n      </div>\r\n    </el-card>\r\n\r\n    <!-- 公告编辑/查看对话框 -->\r\n    <el-dialog\r\n        :title=\"dialogTitle\"\r\n        :visible.sync=\"dialogVisible\"\r\n        width=\"600px\"\r\n        :before-close=\"handleDialogClose\"\r\n    >\r\n      <el-form :model=\"form\" :rules=\"rules\" ref=\"formRef\" label-width=\"80px\">\r\n        <el-form-item label=\"公告标题\" prop=\"title\">\r\n          <el-input v-model=\"form.title\" placeholder=\"请输入公告标题\"></el-input>\r\n        </el-form-item>\r\n\r\n        <el-form-item label=\"公告内容\" prop=\"content\">\r\n          <el-input\r\n              type=\"textarea\"\r\n              :rows=\"6\"\r\n              v-model=\"form.content\"\r\n              placeholder=\"请输入公告内容\"\r\n          ></el-input>\r\n        </el-form-item>\r\n\r\n        <el-form-item label=\"重要公告\">\r\n          <el-switch\r\n              v-model=\"form.important\"\r\n              active-text=\"重要\"\r\n              inactive-text=\"普通\"\r\n          ></el-switch>\r\n        </el-form-item>\r\n\r\n        <el-form-item label=\"立即发布\">\r\n          <el-switch\r\n              v-model=\"form.status\"\r\n              :active-value=\"'published'\"\r\n              :inactive-value=\"'draft'\"\r\n              active-text=\"发布\"\r\n              inactive-text=\"草稿\"\r\n          ></el-switch>\r\n        </el-form-item>\r\n      </el-form>\r\n\r\n      <span slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"dialogVisible = false\">取 消</el-button>\r\n        <el-button type=\"primary\" @click=\"handleSubmit\" :loading=\"submitting\">确 定</el-button>\r\n      </span>\r\n    </el-dialog>\r\n\r\n    <!-- 公告查看对话框 -->\r\n    <el-dialog\r\n        title=\"公告详情\"\r\n        :visible.sync=\"viewDialogVisible\"\r\n        width=\"700px\"\r\n    >\r\n      <div class=\"notice-detail\">\r\n        <h2 class=\"detail-title\">{{ currentNotice.title }}</h2>\r\n        <div class=\"detail-meta\">\r\n          <span>发布时间：{{ currentNotice.createTime }}</span>\r\n          <el-tag v-if=\"currentNotice.important\" type=\"danger\" size=\"small\">重要公告</el-tag>\r\n          <span>阅读量：{{ currentNotice.readCount }}</span>\r\n        </div>\r\n        <div class=\"detail-content\">\r\n          {{ currentNotice.content }}\r\n        </div>\r\n      </div>\r\n      <span slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button @click=\"viewDialogVisible = false\">关 闭</el-button>\r\n      </span>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: 'NoticeManage',\r\n  data() {\r\n    return {\r\n      loading: false,\r\n      searchKeyword: '',\r\n      noticeList: [],\r\n      selectedRows: [],\r\n      pagination: {\r\n        currentPage: 1,\r\n        pageSize: 10,\r\n        total: 0\r\n      },\r\n      dialogVisible: false,\r\n      viewDialogVisible: false,\r\n      submitting: false,\r\n      dialogType: 'add', // add, edit\r\n      form: {\r\n        id: null,\r\n        title: '',\r\n        content: '',\r\n        important: false,\r\n        status: 'draft'\r\n      },\r\n      currentNotice: {},\r\n      rules: {\r\n        title: [\r\n          { required: true, message: '请输入公告标题', trigger: 'blur' },\r\n          { min: 2, max: 100, message: '标题长度在 2 到 100 个字符', trigger: 'blur' }\r\n        ],\r\n        content: [\r\n          { required: true, message: '请输入公告内容', trigger: 'blur' },\r\n          { min: 10, message: '公告内容至少10个字符', trigger: 'blur' }\r\n        ]\r\n      }\r\n    }\r\n  },\r\n  computed: {\r\n    dialogTitle() {\r\n      return this.dialogType === 'add' ? '发布公告' : '编辑公告'\r\n    }\r\n  },\r\n  mounted() {\r\n    this.loadNoticeList()\r\n  },\r\n  methods: {\r\n    // 加载公告列表\r\n    async loadNoticeList() {\r\n      this.loading = true\r\n      try {\r\n        // 模拟API调用\r\n        setTimeout(() => {\r\n          this.noticeList = [\r\n            {\r\n              id: 1,\r\n              title: '关于2024年春节放假安排的通知',\r\n              content: '根据国家法定节假日安排，结合公司实际情况，现将2024年春节放假安排通知如下...',\r\n              createTime: '2024-01-15 10:30:00',\r\n              readCount: 156,\r\n              important: true,\r\n              status: 'published'\r\n            },\r\n            {\r\n              id: 2,\r\n              title: '公司年度体检安排',\r\n              content: '为保障员工身体健康，公司将于下周一组织年度体检，请各位员工合理安排时间...',\r\n              createTime: '2024-01-10 14:20:00',\r\n              readCount: 89,\r\n              important: false,\r\n              status: 'published'\r\n            },\r\n            {\r\n              id: 3,\r\n              title: '新员工培训计划',\r\n              content: '为提高新员工业务能力，人力资源部将组织新员工培训，具体安排如下...',\r\n              createTime: '2024-01-08 09:15:00',\r\n              readCount: 45,\r\n              important: false,\r\n              status: 'published'\r\n            }\r\n          ]\r\n          this.pagination.total = this.noticeList.length\r\n          this.loading = false\r\n        }, 500)\r\n      } catch (error) {\r\n        console.error('加载公告列表失败:', error)\r\n        this.loading = false\r\n      }\r\n    },\r\n\r\n    // 搜索\r\n    handleSearch() {\r\n      this.pagination.currentPage = 1\r\n      this.loadNoticeList()\r\n    },\r\n\r\n    // 发布公告\r\n    handleAdd() {\r\n      this.dialogType = 'add'\r\n      this.form = {\r\n        id: null,\r\n        title: '',\r\n        content: '',\r\n        important: false,\r\n        status: 'draft'\r\n      }\r\n      this.dialogVisible = true\r\n      this.$nextTick(() => {\r\n        this.$refs.formRef?.clearValidate()\r\n      })\r\n    },\r\n\r\n    // 编辑公告\r\n    handleEdit(row) {\r\n      this.dialogType = 'edit'\r\n      this.form = { ...row }\r\n      this.dialogVisible = true\r\n    },\r\n\r\n    // 查看公告\r\n    handleView(row) {\r\n      this.currentNotice = { ...row }\r\n      this.viewDialogVisible = true\r\n    },\r\n\r\n    // 删除公告\r\n    handleDelete(row) {\r\n      this.$confirm('确定要删除该公告吗？', '提示', {\r\n        type: 'warning'\r\n      }).then(async () => {\r\n        try {\r\n          // 模拟删除API调用\r\n          this.$message.success('删除成功')\r\n          this.loadNoticeList()\r\n        } catch (error) {\r\n          this.$message.error('删除失败')\r\n        }\r\n      })\r\n    },\r\n\r\n    // 批量删除\r\n    handleBatchDelete() {\r\n      if (this.selectedRows.length === 0) return\r\n\r\n      this.$confirm(`确定要删除选中的 ${this.selectedRows.length} 条公告吗？`, '提示', {\r\n        type: 'warning'\r\n      }).then(async () => {\r\n        try {\r\n          // 模拟批量删除API调用\r\n          this.$message.success('删除成功')\r\n          this.selectedRows = []\r\n          this.loadNoticeList()\r\n        } catch (error) {\r\n          this.$message.error('删除失败')\r\n        }\r\n      })\r\n    },\r\n\r\n    // 提交表单\r\n    handleSubmit() {\r\n      this.$refs.formRef.validate(async (valid) => {\r\n        if (!valid) return\r\n\r\n        this.submitting = true\r\n        try {\r\n          // 模拟API调用\r\n          setTimeout(() => {\r\n            this.$message.success(this.dialogType === 'add' ? '发布成功' : '更新成功')\r\n            this.dialogVisible = false\r\n            this.submitting = false\r\n            this.loadNoticeList()\r\n          }, 1000)\r\n        } catch (error) {\r\n          this.$message.error('操作失败')\r\n          this.submitting = false\r\n        }\r\n      })\r\n    },\r\n\r\n    // 对话框关闭\r\n    handleDialogClose() {\r\n      this.dialogVisible = false\r\n    },\r\n\r\n    // 选择变化\r\n    handleSelectionChange(selection) {\r\n      this.selectedRows = selection\r\n    },\r\n\r\n    // 分页大小变化\r\n    handleSizeChange(size) {\r\n      this.pagination.pageSize = size\r\n      this.pagination.currentPage = 1\r\n      this.loadNoticeList()\r\n    },\r\n\r\n    // 当前页变化\r\n    handleCurrentChange(page) {\r\n      this.pagination.currentPage = page\r\n      this.loadNoticeList()\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.notice-manage {\r\n  padding: 20px;\r\n}\r\n\r\n.page-header {\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.page-header h1 {\r\n  margin: 0;\r\n  color: #303133;\r\n  font-size: 24px;\r\n}\r\n\r\n.page-header p {\r\n  margin: 8px 0 0 0;\r\n  color: #909399;\r\n  font-size: 14px;\r\n}\r\n\r\n.main-card {\r\n  border-radius: 8px;\r\n}\r\n\r\n.toolbar {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.search-box {\r\n  display: flex;\r\n  gap: 10px;\r\n}\r\n\r\n.notice-title {\r\n  color: #409EFF;\r\n  cursor: pointer;\r\n}\r\n\r\n.notice-title:hover {\r\n  text-decoration: underline;\r\n}\r\n\r\n.pagination {\r\n  margin-top: 20px;\r\n  text-align: right;\r\n}\r\n\r\n.notice-detail {\r\n  padding: 10px;\r\n}\r\n\r\n.detail-title {\r\n  margin: 0 0 16px 0;\r\n  color: #303133;\r\n  font-size: 20px;\r\n  text-align: center;\r\n}\r\n\r\n.detail-meta {\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n  margin-bottom: 20px;\r\n  padding-bottom: 16px;\r\n  border-bottom: 1px solid #ebeef5;\r\n  color: #909399;\r\n  font-size: 14px;\r\n}\r\n\r\n.detail-content {\r\n  line-height: 1.8;\r\n  color: #606266;\r\n  white-space: pre-wrap;\r\n}\r\n</style>"]}]}